---

---

<button
  type="button"
  data-theme-toggle
  class="hf-button hf-button-outline hf-button-icon"
  aria-label="Toggle theme"
  aria-pressed="false"
>
  <svg
    class="theme-icon theme-icon-light"
    aria-hidden="true"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
    <path
      d="M12 2.75V5M12 19v2.25M4.93 4.93l1.6 1.6M17.47 17.47l1.6 1.6M2.75 12H5M19 12h2.25M4.93 19.07l1.6-1.6M17.47 6.53l1.6-1.6"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
    >
    </path>
  </svg>

  <svg
    class="theme-icon theme-icon-dark"
    aria-hidden="true"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M20.25 14.4A7.85 7.85 0 0 1 9.6 3.75 8.4 8.4 0 1 0 20.25 14.4Z"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linejoin="round"
    >
    </path>
  </svg>
</button>

<style>
.theme-icon {
  display: block;
}

.theme-icon-dark {
  display: none;
}

:global(.dark) .theme-icon-light {
  display: none;
}

:global(.dark) .theme-icon-dark {
  display: block;
}
</style>

<script>
declare global {
  interface Window {
    happyFormatterThemeToggleReady?: boolean;
  }
}

if (!window.happyFormatterThemeToggleReady) {
  window.happyFormatterThemeToggleReady = true;

  const themeKey = "theme";
  const themePreferenceKey = "theme-preference";
  const editorThemeKey = "codemirror-theme";
  const systemThemeQuery = window.matchMedia("(prefers-color-scheme: dark)");
  const defaultEditorThemeByMode = {
    light: "github-light",
    dark: "github-dark",
  };
  const editorThemesByMode = {
    light: new Set([
      "github-light",
      "solarized-light",
      "atom-one-light",
      "vitesse-light",
      "catppuccin-latte",
    ]),
    dark: new Set([
      "github-dark",
      "one-dark-pro",
      "nord",
      "material-theme-palenight",
      "dracula",
      "solarized-dark",
      "monokai",
      "atom-one-dark",
      "vscode-dark",
      "vitesse-dark",
      "catppuccin-mocha",
    ]),
  };

  const readStorage = (key: string) => {
    try {
      return window.localStorage.getItem(key);
    } catch {
      return null;
    }
  };

  const writeStorage = (key: string, value: string) => {
    try {
      window.localStorage.setItem(key, value);
    } catch {
      // Storage can be unavailable in private browsing modes.
    }
  };

  const isMode = (value: string | null): value is "light" | "dark" =>
    value === "light" || value === "dark";

  const isPreference = (
    value: string | null,
  ): value is "light" | "dark" | "system" =>
    value === "system" || isMode(value);

  const getStoredPreference = () => {
    const storedPreference = readStorage(themePreferenceKey);
    return isPreference(storedPreference) ? storedPreference : "system";
  };

  const resolvePreference = (preference: "light" | "dark" | "system") => {
    if (preference !== "system") {
      return preference;
    }

    return systemThemeQuery.matches ? "dark" : "light";
  };

  const getCurrentMode = () => {
    const root = document.documentElement;
    const datasetMode = root.dataset.theme ?? null;
    if (isMode(datasetMode)) {
      return datasetMode;
    }
    return root.classList.contains("dark")
      ? "dark"
      : resolvePreference(getStoredPreference());
  };

  const getCurrentPreference = () => {
    const root = document.documentElement;
    const datasetPreference = root.dataset.themePreference ?? null;
    return isPreference(datasetPreference)
      ? datasetPreference
      : getStoredPreference();
  };

  const isEditorThemeForMode = (
    theme: string | null,
    mode: "light" | "dark",
  ): theme is string => Boolean(theme && editorThemesByMode[mode].has(theme));

  const getEditorThemeForMode = (mode: "light" | "dark") => {
    const modeKey = `codemirror-theme-${mode}`;
    const storedForMode = readStorage(modeKey);
    if (isEditorThemeForMode(storedForMode, mode)) {
      return storedForMode;
    }

    const current = readStorage(editorThemeKey);
    if (isEditorThemeForMode(current, mode)) {
      return current;
    }

    return defaultEditorThemeByMode[mode];
  };

  const updateButtons = (
    mode: "light" | "dark",
    preference: "light" | "dark" | "system",
  ) => {
    const nextMode = mode === "dark" ? "light" : "dark";
    const label = preference === "system"
      ? `Following system ${mode} theme. Switch to ${nextMode} theme.`
      : `Switch to ${nextMode} theme`;

    document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
      button.setAttribute("aria-label", label);
      button.setAttribute("title", label);
      button.setAttribute("aria-pressed", String(mode === "dark"));
    });
  };

  const applyThemePreference = (
    preference: "light" | "dark" | "system",
    persistPreference = false,
  ) => {
    const mode = resolvePreference(preference);
    const root = document.documentElement;
    const editorTheme = getEditorThemeForMode(mode);

    root.classList.toggle("dark", mode === "dark");
    root.dataset.theme = mode;
    root.dataset.themePreference = preference;
    root.style.colorScheme = mode;
    writeStorage(themeKey, mode);
    if (persistPreference) {
      writeStorage(themePreferenceKey, preference);
    }
    writeStorage(editorThemeKey, editorTheme);
    writeStorage(`codemirror-theme-${mode}`, editorTheme);
    updateButtons(mode, preference);

    window.dispatchEvent(
      new CustomEvent("happyformatter:theme-change", {
        detail: { editorTheme, preference, theme: mode },
      }),
    );
  };

  applyThemePreference(getCurrentPreference());

  document.addEventListener("click", (event) => {
    const target = (event.target as Element | null)?.closest(
      "[data-theme-toggle]",
    );

    if (!target) {
      return;
    }

    applyThemePreference(getCurrentMode() === "dark" ? "light" : "dark", true);
  });

  window.addEventListener("storage", (event) => {
    if (event.key === themePreferenceKey) {
      applyThemePreference(
        isPreference(event.newValue) ? event.newValue : "system",
      );
    }
  });

  const handleSystemThemeChange = () => {
    if (getCurrentPreference() === "system") {
      applyThemePreference("system");
    }
  };

  systemThemeQuery.addEventListener("change", handleSystemThemeChange);
}
</script>
