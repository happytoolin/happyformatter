---
import LanguageIcon from "@/icons/languages/LanguageIcon.astro";
import { getLanguageVariants } from "@/lib/seo-variants";

interface LanguageRelation {
  related: string[];
  features: string[];
  contextualReasons: Record<string, string>;
}

interface BaseTool {
  name: string;
  url: string;
  type: string;
}

interface Tool extends BaseTool {
  reason?: string;
  description?: string;
  category?: string;
}

const languageRelationships: Record<string, LanguageRelation> = {
  javascript: {
    related: ["typescript", "json", "html", "css"],
    features: ["formatter", "minifier", "biome-formatter"],
    contextualReasons: {
      typescript: "Try TypeScript with Biome formatter",
      json: "Format and validate JSON data",
      html: "Format HTML markup",
      css: "Minify and style CSS code",
    },
  },
  typescript: {
    related: ["javascript", "json", "html"],
    features: ["formatter", "minifier", "biome-formatter"],
    contextualReasons: {
      javascript: "Format JavaScript with Biome",
      json: "Compress and validate JSON files",
      html: "Clean and format HTML structure",
    },
  },
  html: {
    related: ["css", "javascript", "markdown", "xml"],
    features: ["formatter", "beautifier"],
    contextualReasons: {
      css: "Style and compress CSS code",
      javascript: "Enhanced JavaScript formatting",
      markdown: "Format markdown documents",
      xml: "Structure and validate XML data",
    },
  },
  css: {
    related: ["scss", "html", "javascript"],
    features: ["formatter", "minifier", "beautifier"],
    contextualReasons: {
      scss: "Advanced CSS preprocessing",
      html: "Comprehensive HTML formatting",
      javascript: "Modern JavaScript tooling",
    },
  },
  scss: {
    related: ["css", "html"],
    features: ["formatter", "minifier"],
    contextualReasons: {
      css: "Advanced minification and styling support",
      html: "Format HTML markup",
    },
  },
  json: {
    related: ["yaml", "xml", "javascript", "typescript"],
    features: ["formatter", "minifier", "pretty-print"],
    contextualReasons: {
      yaml: "Configuration data formatting",
      xml: "Format XML",
      javascript: "JSON in JavaScript projects",
      typescript: "TypeScript configuration",
    },
  },
  yaml: {
    related: ["json", "toml", "xml"],
    features: ["formatter", "pretty-print"],
    contextualReasons: {
      json: "Data file formatting",
      toml: "Configuration file formatting",
      xml: "Configuration file formatting",
    },
  },
  toml: {
    related: ["yaml", "json"],
    features: ["formatter", "pretty-print"],
    contextualReasons: {
      yaml: "Configuration file formatting",
      json: "Data file formatting",
    },
  },
  xml: {
    related: ["json", "html"],
    features: ["formatter", "minifier", "beautifier"],
    contextualReasons: {
      json: "Markup and data formatting",
      html: "Document structure formatting",
    },
  },
  python: {
    related: ["python-ruff", "json", "yaml"],
    features: ["formatter"],
    contextualReasons: {
      "python-ruff": "Fast Python formatting",
      json: "Python data file handling",
      yaml: "Python configuration files",
    },
  },
  "python-ruff": {
    related: ["python", "json"],
    features: ["formatter"],
    contextualReasons: {
      python: "Standard Python formatting",
      json: "Data file processing",
    },
  },
  go: {
    related: ["c", "cpp", "json"],
    features: ["formatter"],
    contextualReasons: {
      c: "Format C",
      cpp: "C-family service code",
      json: "API payload companion",
    },
  },
  c: {
    related: ["cpp", "objectivec", "csharp", "go"],
    features: ["formatter"],
    contextualReasons: {
      cpp: "Adjacent C-family source",
      objectivec: "Format Objective-C with clang-format",
      csharp: "Managed C-family source",
      go: "Systems-style service code",
    },
  },
  cpp: {
    related: ["c", "objectivecpp", "csharp", "go"],
    features: ["formatter"],
    contextualReasons: {
      c: "Format C",
      objectivecpp: "Format Objective-C++ with clang-format",
      csharp: "Managed C-family source",
      go: "Compiled service source",
    },
  },
  objectivec: {
    related: ["c", "objectivecpp", "cpp"],
    features: ["formatter"],
    contextualReasons: {
      c: "Format C",
      objectivecpp: "Format mixed Objective-C++ sources",
      cpp: "Format C++",
    },
  },
  objectivecpp: {
    related: ["cpp", "objectivec", "c"],
    features: ["formatter"],
    contextualReasons: {
      cpp: "Format C++",
      objectivec: "Format Objective-C",
      c: "Format C",
    },
  },
  csharp: {
    related: ["c", "cpp", "json"],
    features: ["formatter"],
    contextualReasons: {
      c: "Native C-family source",
      cpp: "C++ source companion",
      json: "Configuration and payload data",
    },
  },
  java: {
    related: ["json", "xml"],
    features: ["formatter"],
    contextualReasons: {
      json: "Service payload data",
      xml: "Format XML markup",
    },
  },
  php: {
    related: ["php-mago", "json", "html", "xml"],
    features: ["formatter"],
    contextualReasons: {
      "php-mago": "Alternative formatting option",
      json: "Request and response payloads",
      html: "Format HTML markup",
      xml: "Format XML markup",
    },
  },
  "php-mago": {
    related: ["php", "json"],
    features: ["formatter"],
    contextualReasons: {
      php: "Standard formatter available",
      json: "Request and response payloads",
    },
  },
  rust: {
    related: ["c", "cpp", "go"],
    features: ["formatter"],
    contextualReasons: {
      c: "Format C",
      cpp: "C++ source companion",
      go: "Compiled service source",
    },
  },
  sql: {
    related: ["json", "yaml"],
    features: ["formatter", "beautifier"],
    contextualReasons: {
      json: "Structured result data",
      yaml: "Configuration data",
    },
  },
  dart: {
    related: ["json", "yaml"],
    features: ["formatter"],
    contextualReasons: {
      json: "Runtime data payloads",
      yaml: "Configuration data",
    },
  },
  lua: {
    related: ["json", "yaml"],
    features: ["formatter"],
    contextualReasons: {
      json: "Runtime data payloads",
      yaml: "Configuration data",
    },
  },
  markdown: {
    related: ["html", "xml"],
    features: ["formatter", "beautifier"],
    contextualReasons: {
      html: "Format HTML markup",
      xml: "Format XML markup",
    },
  },
  proto: {
    related: ["json", "yaml"],
    features: ["formatter", "beautifier"],
    contextualReasons: {
      json: "Structured schema payloads",
      yaml: "Configuration data",
    },
  },
  zig: {
    related: ["c", "cpp", "go"],
    features: ["formatter"],
    contextualReasons: {
      c: "Format C",
      cpp: "C++ source companion",
      go: "Compiled service source",
    },
  },
};

// Languages that actually have working minifiers implemented
const languagesWithMinifiers = [
  "css",
  "scss",
  "javascript",
  "typescript",
  "json",
  "xml",
];

const allTools: BaseTool[] = [
  { name: "HTML", url: "/html", type: "FMT" },
  { name: "CSS", url: "/css", type: "FMT" },
  { name: "JavaScript", url: "/javascript", type: "FMT" },
  { name: "JavaScript Biome", url: "/javascript-biome", type: "FMT" },
  { name: "TypeScript", url: "/typescript", type: "FMT" },
  { name: "TypeScript Biome", url: "/typescript-biome", type: "FMT" },
  { name: "JSON", url: "/json", type: "FMT" },
  { name: "XML", url: "/xml", type: "FMT" },
  { name: "YAML", url: "/yaml", type: "FMT" },
  { name: "TOML", url: "/toml", type: "FMT" },
  { name: "SQL", url: "/sql", type: "FMT" },
  { name: "Go", url: "/go", type: "FMT" },
  { name: "Dart", url: "/dart", type: "FMT" },
  { name: "SCSS", url: "/scss", type: "FMT" },
  { name: "Java", url: "/java", type: "FMT" },
  { name: "Lua", url: "/lua", type: "FMT" },
  { name: "Python", url: "/python", type: "FMT" },
  { name: "Python Ruff", url: "/python-ruff", type: "FMT" },
  { name: "Rust", url: "/rust", type: "FMT" },
  { name: "Markdown", url: "/markdown", type: "FMT" },
  { name: "C#", url: "/csharp", type: "FMT" },
  { name: "C", url: "/c", type: "FMT" },
  { name: "C++", url: "/cpp", type: "FMT" },
  { name: "Objective-C", url: "/objectivec", type: "FMT" },
  { name: "Objective-C++", url: "/objectivecpp", type: "FMT" },
  { name: "PHP", url: "/php", type: "FMT" },
  { name: "PHP Mago", url: "/php-mago", type: "FMT" },
  { name: "Proto", url: "/proto", type: "FMT" },
  { name: "Zig", url: "/zig", type: "FMT" },
];

interface Props {
  currentLanguage?: string;
  currentVariant?: string | null;
  minify?: boolean;
}

const props = Astro.props as Props;

const {
  currentLanguage,
  currentVariant: _currentVariant = null,
  minify = false,
} = props;

// Get language variants for the current language
const variants = getLanguageVariants(currentLanguage || "");

// Get related tools for the current language
const getRelatedTools = () => {
  if (!currentLanguage || !languageRelationships[currentLanguage]) {
    return [];
  }

  const relationship = languageRelationships[currentLanguage];
  const relatedTools = relationship.related
    .map(lang => {
      const tool = allTools.find(t => t.url === `/${lang}`);
      if (tool) {
        return {
          name: tool.name,
          url: tool.url,
          type: tool.type,
          reason: `Format ${tool.name}`,
          description: `Format ${tool.name}`,
        } as Tool;
      }
      return null;
    })
    .filter((tool): tool is Tool => tool !== null);

  return relatedTools;
};

// Mix variants and related tools, prioritizing variety
const getMixedRecommendations = () => {
  const related = getRelatedTools();
  const allRecommendations: Tool[] = [];

  // Add up to 3 related tools first
  related.slice(0, 3).forEach(tool => {
    allRecommendations.push({
      name: tool.name,
      url: tool.url,
      type: tool.type,
      reason: tool.reason,
      description: tool.description,
      category: "related",
    });
  });

  // Add up to 3 variants
  variants.slice(0, 3).forEach(variant => {
    allRecommendations.push({
      name: variant.h1,
      url: `/${currentLanguage}-${variant.slug}`,
      type: "VAR",
      reason: "Alternate workflow",
      description: variant.description.split(".")[0] + ".",
      category: "variant",
    });
  });

  // If we don't have enough recommendations, add more related tools or variants
  if (allRecommendations.length < 6) {
    const remainingRelated = related.slice(3);
    const remainingVariants = variants.slice(3);

    // Alternate between adding more related tools and variants
    let i = 0;
    while (
      allRecommendations.length < 6
      && i < Math.max(remainingRelated.length, remainingVariants.length)
    ) {
      if (i < remainingRelated.length) {
        const tool = remainingRelated[i];
        allRecommendations.push({
          name: tool.name,
          url: tool.url,
          type: tool.type,
          reason: tool.reason,
          description: tool.description,
          category: "related",
        });
      }
      if (allRecommendations.length < 6 && i < remainingVariants.length) {
        allRecommendations.push({
          name: remainingVariants[i].h1,
          url: `/${currentLanguage}-${remainingVariants[i].slug}`,
          type: "VAR",
          reason: "Alternate workflow",
          description: remainingVariants[i].description.split(".")[0] + ".",
          category: "variant",
        });
      }
      i++;
    }
  }

  // If still not enough, add popular tools
  if (allRecommendations.length < 6) {
    const popularTools = [
      {
        name: "JSON",
        url: "/json",
        type: "FMT",
        reason: "Format JSON",
        description: "Format JSON",
        category: "fallback",
      },
      {
        name: "JavaScript",
        url: "/javascript",
        type: "FMT",
        reason: "Format JavaScript",
        description: "Format JavaScript",
        category: "fallback",
      },
      {
        name: "Python",
        url: "/python",
        type: "FMT",
        reason: "Format Python",
        description: "Format Python",
        category: "fallback",
      },
    ];

    popularTools.forEach(tool => {
      if (
        allRecommendations.length < 6
        && !allRecommendations.find(r => r.url === tool.url)
      ) {
        allRecommendations.push(tool);
      }
    });
  }

  return allRecommendations.slice(0, 6);
};

const getToolIcon = (url: string) => {
  const urlParts = url.split("/").filter(Boolean);
  if (urlParts[0] === "minify") {
    return urlParts[1] ?? urlParts[0];
  }
  return urlParts.length >= 2 ? urlParts.join("-") : urlParts[0];
};

const getToolId = (url: string) => {
  const parts = url.split("/").filter(Boolean);
  return parts[parts.length - 1] ?? url.replace("/", "");
};

const getToolSummary = (tool: Tool) => {
  if (tool.category === "variant") {
    return "Open this version.";
  }

  return `Format ${tool.name}.`;
};

const recommendations = getMixedRecommendations();
const showSection = currentLanguage && recommendations.length > 0;
---

{showSection && (
  <section
    class="border-b border-border bg-card py-16 sm:py-20"
    aria-labelledby="tools-heading"
  >
    <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(240px,0.28fr)_minmax(0,1fr)] lg:px-8">
      <aside class="border-y border-border py-6 lg:py-7">
        <p class="font-mono text-xs uppercase text-muted-foreground">
          More
        </p>
        <h2
          id="tools-heading"
          class="mt-5 max-w-sm text-4xl font-semibold leading-none text-foreground md:text-5xl"
        >
          More formatters.
        </h2>
        <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
          Open another formatter from here.
        </p>
        <a
          href="#more-tools"
          class="mt-6 inline-flex rounded-md border border-border bg-background px-3 py-2 text-sm font-medium text-foreground transition-colors hover:border-foreground hover:bg-secondary active:translate-y-px"
        >
          All tools
        </a>
      </aside>

      <div class="overflow-hidden rounded-lg border border-border bg-background">
        <div class="grid grid-cols-[1fr_40px] gap-4 border-b border-border px-4 py-3 font-mono text-xs uppercase text-muted-foreground">
          <span>Tool</span>
          <span class="text-right">Open</span>
        </div>

        <div class="divide-y divide-border">
          {recommendations.map((tool, _index) => {
            const isCurrentLanguage = tool.url === `/${currentLanguage}`;
            const isVariant = tool.category === "variant";
            const targetLang = getToolId(tool.url);
            const hasMinifier = languagesWithMinifiers.includes(targetLang);
            const actionUrl = isCurrentLanguage
              ? (minify && hasMinifier ? `/minify${tool.url}` : tool.url)
              : (minify && hasMinifier ? `/minify${tool.url}` : tool.url);

            return (
              <a
                href={actionUrl}
                class="group grid min-h-[88px] grid-cols-[1fr_40px] items-center gap-4 px-4 py-4 transition-colors hover:bg-secondary active:translate-y-px"
              >
                <div class="flex min-w-0 items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-md border border-border bg-card text-muted-foreground transition-colors group-hover:border-foreground group-hover:text-foreground">
                    {isVariant && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M9 11l3 3L22 4" />
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                      </svg>
                    )}
                    {!isVariant && (
                      <LanguageIcon
                        icon={getToolIcon(tool.url)}
                        class="h-5 w-5"
                        title={tool.name}
                      />
                    )}
                  </div>

                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <span
                        class="font-mono text-xs uppercase text-muted-foreground"
                      >
                        {tool.type}
                      </span>
                      <h3 class="truncate text-base font-semibold text-foreground sm:text-lg">
                        {tool.name}
                      </h3>
                      {isCurrentLanguage && hasMinifier && (
                        <span
                          class="rounded-sm border border-border px-2 py-1 font-mono text-[10px] uppercase text-muted-foreground"
                        >
                          {minify ? "Format" : "Minify"}
                        </span>
                      )}
                    </div>
                    <p class="mt-1 text-sm leading-6 text-muted-foreground">
                      {getToolSummary(tool)}
                    </p>
                  </div>
                </div>

                <span
                  class="text-right font-mono text-xs text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-foreground"
                  aria-hidden="true"
                >
                  -&gt;
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </section>
)}
