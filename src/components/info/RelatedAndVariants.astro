};

// Languages that actually have working minifiers implemented
const languagesWithMinifiers = [
  "css",
  "scss",
  "html",
  "javascript",
  "javascript-biome",
  "javascript-oxc",
  "typescript",
  "typescript-biome",
  "typescript-oxc",
  "json",
  "xml",
  "graphql",
  "shell",
];

const allTools: BaseTool[] = [
  { name: "HTML", url: "/html", type: "FMT" },
  { name: "Vue", url: "/vue", type: "FMT" },
  { name: "Svelte", url: "/svelte", type: "FMT" },
  { name: "Astro", url: "/astro", type: "FMT" },
  { name: "Angular", url: "/angular", type: "FMT" },
  { name: "Handlebars", url: "/handlebars", type: "FMT" },
  { name: "Jinja", url: "/jinja", type: "FMT" },
  { name: "Twig", url: "/twig", type: "FMT" },
  { name: "CSS", url: "/css", type: "FMT" },
  { name: "Less", url: "/less", type: "FMT" },
  { name: "Sass", url: "/sass", type: "FMT" },
  { name: "JavaScript", url: "/javascript", type: "FMT" },
  { name: "JavaScript Biome", url: "/javascript-biome", type: "FMT" },
  { name: "JavaScript OXC", url: "/javascript-oxc", type: "FMT" },
  { name: "TypeScript", url: "/typescript", type: "FMT" },
  { name: "TypeScript Biome", url: "/typescript-biome", type: "FMT" },
  { name: "TypeScript OXC", url: "/typescript-oxc", type: "FMT" },
  { name: "JSON", url: "/json", type: "FMT" },
  { name: "JSONC", url: "/jsonc", type: "FMT" },
  { name: "JSON5", url: "/json5", type: "FMT" },
  { name: "XML", url: "/xml", type: "FMT" },
  { name: "YAML", url: "/yaml", type: "FMT" },
  { name: "TOML", url: "/toml", type: "FMT" },
  { name: "SQL", url: "/sql", type: "FMT" },
  { name: "GraphQL", url: "/graphql", type: "FMT" },
  { name: "Shell", url: "/shell", type: "FMT" },
  { name: "Go", url: "/go", type: "FMT" },
  { name: "Dart", url: "/dart", type: "FMT" },
  { name: "SCSS", url: "/scss", type: "FMT" },
  { name: "Java", url: "/java", type: "FMT" },
  { name: "Lua", url: "/lua", type: "FMT" },
  { name: "Python", url: "/python", type: "FMT" },
  { name: "Python Ruff", url: "/python-ruff", type: "FMT" },
  { name: "Rust", url: "/rust", type: "FMT" },
  { name: "Markdown", url: "/markdown", type: "FMT" },
  { name: "MDX", url: "/mdx", type: "FMT" },
  { name: "C#", url: "/csharp", type: "FMT" },
  { name: "C", url: "/c", type: "FMT" },
  { name: "C++", url: "/cpp", type: "FMT" },
  { name: "Objective-C", url: "/objectivec", type: "FMT" },
  { name: "Objective-C++", url: "/objectivecpp", type: "FMT" },
  { name: "PHP", url: "/php", type: "FMT" },
  { name: "PHP Mago", url: "/php-mago", type: "FMT" },
  { name: "Proto", url: "/proto", type: "FMT" },
  { name: "Zig", url: "/zig", type: "FMT" },
];

interface Props {
  currentLanguage?: string;
  currentVariant?: string | null;
  minify?: boolean;
}

const props = Astro.props as Props;

const {
  currentLanguage,
  currentVariant: _currentVariant = null,
  minify = false,
} = props;

// Formatter variants are useful on formatter pages; minifier pages link to the
// dedicated minifier route only to avoid thin duplicate URLs.
const variants = minify ? [] : getLanguageVariants(currentLanguage || "");
const canonicalVariants = variants.filter(variant => variant.slug !== "minify");

const getLanguageName = (language: string) => {
  const tool = allTools.find(item => item.url === `/${language}`);
  if (tool) {
    return tool.name;
  }

  return language
    .split("-")
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
};

const getVariantRecommendation = (
  language: string,
  variant: VariantLink,
): Pick<Tool, "name" | "description"> => {
  const languageName = getLanguageName(language);

  switch (variant.slug) {
    case "online":
      return {
        name: `Browser ${languageName} Formatter`,
        description: `Format ${languageName} in the browser.`,
      };
    case "secure":
    case "private":
      return {
        name: `Private ${languageName} Formatter`,
        description: "Keep code on this device while formatting.",
      };
    case "biome":
      return {
        name: `${languageName} Biome Formatter`,
        description: `Format ${languageName} with Biome.`,
      };
    case "ruff":
      return {
        name: `${languageName} Ruff Formatter`,
        description: `Format ${languageName} with Ruff.`,
      };
    case "mago":
      return {
        name: `${languageName} Mago Formatter`,
        description: `Format ${languageName} with Mago.`,
      };
    case "oxc":
      return {
        name: `${languageName} OXC Formatter`,
        description: `Format ${languageName} with OXC.`,
      };
    case "beautifier":
    case "pretty":
    case "prettify":
      return {
        name: `${languageName} Pretty Printer`,
        description: `Make ${languageName} easier to read.`,
      };
    default:
      return {
        name: `${languageName} Formatter`,
        description: `Format ${languageName} in the browser.`,
      };
  }
};

// Get related tools for the current language
const getRelatedTools = () => {
  if (!currentLanguage || !languageRelationships[currentLanguage]) {
    return [];
  }

  const relationship = languageRelationships[currentLanguage];
  const relatedTools = relationship.related
    .map(lang => {
      const tool = allTools.find(t => t.url === `/${lang}`);
      if (tool) {
        return {
          name: tool.name,
          url: tool.url,
          type: tool.type,
          reason: `Format ${tool.name}`,
          description: `Format ${tool.name}`,
        } as Tool;
      }
      return null;
    })
    .filter((tool): tool is Tool => tool !== null);

  return relatedTools;
};

// Mix variants and related tools, prioritizing variety
const getMixedRecommendations = () => {
  const related = getRelatedTools();
  const allRecommendations: Tool[] = [];

  // Add up to 3 related tools first
  related.slice(0, 3).forEach(tool => {
    allRecommendations.push({
      name: tool.name,
      url: tool.url,
      type: tool.type,
      reason: tool.reason,
      description: tool.description,
      category: "related",
    });
  });

  // Add up to 3 variants
  canonicalVariants.slice(0, 3).forEach(variant => {
    const display = getVariantRecommendation(currentLanguage || "", variant);
    allRecommendations.push({
      name: display.name,
      url: `/${currentLanguage}-${variant.slug}`,
      type: "VAR",
      reason: "Alternate workflow",
      description: display.description,
      category: "variant",
    });
  });

  // If we don't have enough recommendations, add more related tools or variants
  if (allRecommendations.length < 6) {
    const remainingRelated = related.slice(3);
    const remainingVariants = canonicalVariants.slice(3);

    // Alternate between adding more related tools and variants
    let i = 0;
    while (
      allRecommendations.length < 6
      && i < Math.max(remainingRelated.length, remainingVariants.length)
    ) {
      if (i < remainingRelated.length) {
        const tool = remainingRelated[i];
        allRecommendations.push({
          name: tool.name,
          url: tool.url,
          type: tool.type,
          reason: tool.reason,
          description: tool.description,
          category: "related",
        });
      }
      if (allRecommendations.length < 6 && i < remainingVariants.length) {
        const variant = remainingVariants[i];
        const display = getVariantRecommendation(
          currentLanguage || "",
          variant,
        );
        allRecommendations.push({
          name: display.name,
          url: `/${currentLanguage}-${variant.slug}`,
          type: "VAR",
          reason: "Alternate workflow",
          description: display.description,
          category: "variant",
        });
      }
      i++;
    }
  }

  // If still not enough, add popular tools
  if (allRecommendations.length < 6) {
    const popularTools = [
      {
        name: "JSON",
        url: "/json",
        type: "FMT",
        reason: "Format JSON",
        description: "Format JSON",
        category: "fallback",
      },
      {
        name: "JavaScript",
        url: "/javascript",
        type: "FMT",
        reason: "Format JavaScript",
        description: "Format JavaScript",
        category: "fallback",
      },
      {
        name: "Python",
        url: "/python",
        type: "FMT",
        reason: "Format Python",
        description: "Format Python",
        category: "fallback",
      },
    ];

    popularTools.forEach(tool => {
      if (
        allRecommendations.length < 6
        && !allRecommendations.find(r => r.url === tool.url)
      ) {
        allRecommendations.push(tool);
      }
    });
  }

  return allRecommendations.slice(0, 6);
};

const getToolIcon = (url: string) => {
  const urlParts = url.split("/").filter(Boolean);
  if (urlParts[0] === "minify") {
    return urlParts[1] ?? urlParts[0];
  }
  return urlParts.length >= 2 ? urlParts.join("-") : urlParts[0];
};

const getToolId = (url: string) => {
  const parts = url.split("/").filter(Boolean);
  return parts[parts.length - 1] ?? url.replace("/", "");
};

const getToolSummary = (tool: Tool) => {
  if (tool.category === "variant") {
    return "Open this formatter variant.";
  }

  return `Format ${tool.name}.`;
};

const getRecommendationType = (tool: Tool) => {
  if (tool.category === "variant") {
    return "Variant";
  }

  return tool.type === "FMT" ? "Formatter" : tool.type;
};

const recommendations = getMixedRecommendations();
const showSection = currentLanguage && recommendations.length > 0;
---

{showSection && (
  <section
    class="border-b border-border bg-card py-16 sm:py-20"
    aria-labelledby="tools-heading"
  >
    <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(240px,0.28fr)_minmax(0,1fr)] lg:px-8">
      <aside class="border-y border-border py-6 lg:py-7">
        <p class="text-sm font-medium text-muted-foreground">
          Related tools
        </p>
        <h2
          id="tools-heading"
          class="mt-4 max-w-sm text-3xl font-semibold leading-tight text-foreground md:text-4xl"
        >
          Keep working in the browser.
        </h2>
        <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
          Move between nearby languages, alternate formatter engines, and
          minifier routes without leaving the workbench.
        </p>
        <a
          href="#more-tools"
          class="mt-6 inline-flex rounded-md border border-border bg-background px-3 py-2 text-sm font-medium text-foreground transition-[background-color,border-color,transform] duration-150 ease-out hover:border-foreground hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring active:translate-y-px motion-reduce:transition-none"
        >
          Browse all tools
        </a>
      </aside>

      <div class="overflow-hidden rounded-lg border border-border bg-background">
        <div class="grid grid-cols-[1fr_40px] gap-4 border-b border-border px-4 py-3 font-mono text-xs uppercase text-muted-foreground">
          <span>Tool</span>
          <span class="text-right">Open</span>
        </div>

        <div class="divide-y divide-border">
          {recommendations.map((tool, _index) => {
            const isCurrentLanguage = tool.url === `/${currentLanguage}`;
            const isVariant = tool.category === "variant";
            const targetLang = getToolId(tool.url);
            const hasMinifier = languagesWithMinifiers.includes(targetLang);
            const actionUrl = isCurrentLanguage
              ? (minify && hasMinifier ? `/minify${tool.url}` : tool.url)
              : (minify && hasMinifier ? `/minify${tool.url}` : tool.url);

            return (
              <a
                href={actionUrl}
                class="group grid min-h-[88px] grid-cols-[1fr_40px] items-center gap-4 px-4 py-4 transition-[background-color,transform] duration-150 ease-out hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-ring active:translate-y-px motion-reduce:transition-none"
              >
                <div class="flex min-w-0 items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-md border border-border bg-card text-muted-foreground transition-colors group-hover:border-foreground group-hover:text-foreground">
                    {isVariant && (
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <path d="M9 11l3 3L22 4" />
                        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11" />
                      </svg>
                    )}
                    {!isVariant && (
                      <LanguageIcon
                        icon={getToolIcon(tool.url)}
                        class="h-5 w-5"
                        title={tool.name}
                      />
                    )}
                  </div>

                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="text-sm text-muted-foreground">
                        {getRecommendationType(tool)}
                      </span>
                      <h3 class="truncate text-base font-semibold text-foreground sm:text-lg">
                        {tool.name}
                      </h3>
                      {isCurrentLanguage && hasMinifier && (
                        <span
                          class="rounded-sm border border-border px-2 py-1 text-xs text-muted-foreground"
                        >
                          {minify ? "Format" : "Minify"}
                        </span>
                      )}
                    </div>
                    <p class="mt-1 text-sm leading-6 text-muted-foreground">
                      {getToolSummary(tool)}
                    </p>
                  </div>
                </div>

                <span
                  class="text-right font-mono text-xs text-muted-foreground transition-[color,transform] duration-150 ease-out group-hover:translate-x-0.5 group-hover:text-foreground motion-reduce:transition-none motion-reduce:group-hover:translate-x-0"
                  aria-hidden="true"
                >
                  -&gt;
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </section>
)}
