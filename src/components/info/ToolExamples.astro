---
import { LANGUAGES } from "@/lib/languages";
import { codeToHtml } from "shiki";

type Props = {
  language: string;
  minify?: boolean;
  variant?: string | null;
};

const { language, minify = false, variant = null } = Astro.props;
const languageConfig = LANGUAGES[language];
const languageName = languageConfig?.name ?? language;
const formatterPath = `/${language}${variant ? `-${variant}` : ""}`;
const minifierPath = `/minify/${language}`;

const examples: Record<
  string,
  { before: string; after: string; minified?: string }
> = {
  json: {
    before: "{\"user\":{\"id\":42,\"name\":\"Ada\"},\"active\":true}",
    after:
      "{\n  \"user\": {\n    \"id\": 42,\n    \"name\": \"Ada\"\n  },\n  \"active\": true\n}",
    minified: "{\"user\":{\"id\":42,\"name\":\"Ada\"},\"active\":true}",
  },
  javascript: {
    before: "const user={name:'Ada',roles:['admin','editor']};",
    after: "const user = { name: 'Ada', roles: ['admin', 'editor'] };",
    minified: "const user={name:'Ada',roles:['admin','editor']};",
  },
  typescript: {
    before:
      "type User={id:number;name:string}\nconst user:User={id:1,name:'Ada'}",
    after:
      "type User = { id: number; name: string };\nconst user: User = { id: 1, name: 'Ada' };",
    minified:
      "type User={id:number;name:string};const user:User={id:1,name:'Ada'};",
  },
  python: {
    before: "def greet(name):\n print(  f\"Hello, {name}\" )",
    after: "def greet(name):\n    print(f\"Hello, {name}\")",
  },
  css: {
    before: ".button {\n color: white;\n background: black;\n}",
    after: ".button {\n  color: white;\n  background: black;\n}",
    minified: ".button{color:white;background:black}",
  },
  yaml: {
    before: "service: api\nports:\n- 80\n- 443",
    after: "service: api\nports:\n  - 80\n  - 443",
  },
  toml: {
    before: "name=\"api\"\n[server]\nport=8080",
    after: "name = \"api\"\n\n[server]\nport = 8080",
  },
  xml: {
    before: "<user><name>Ada</name><active>true</active></user>",
    after: "<user>\n  <name>Ada</name>\n  <active>true</active>\n</user>",
    minified: "<user><name>Ada</name><active>true</active></user>",
  },
  html: {
    before: "<main><h1>Hello</h1><p>Private tools</p></main>",
    after: "<main>\n  <h1>Hello</h1>\n  <p>Private tools</p>\n</main>",
    minified: "<main><h1>Hello</h1><p>Private tools</p></main>",
  },
  vue: {
    before:
      "<template><button @click=\"count++\">{{count}}</button></template>",
    after:
      "<template><button @click=\"count++\">{{ count }}</button></template>",
  },
  svelte: {
    before: "<script>let count=0;</script><button>{count}</button>",
    after: "<script>\nlet count=0;\n</script><button>{count}</button>",
  },
  astro: {
    before: "---\nconst title='Hi'\n---\n<h1>{title}</h1>",
    after: "---\nconst title='Hi'\n---\n<h1>{title}</h1>",
  },
  angular: {
    before: "<div *ngIf=\"ready\">{{value}}</div>",
    after: "<div *ngIf=\"ready\">{{ value }}</div>",
  },
  handlebars: {
    before: "<div>{{#if ready}}{{title}}{{/if}}</div>",
    after: "<div>{{#if ready}}{{title}}{{/if}}</div>",
  },
  jinja: {
    before: "<ul>{% for item in items %}<li>{{ item }}</li>{% endfor %}</ul>",
    after: "<ul>{% for item in items %}<li>{{ item }}</li>{% endfor %}</ul>",
  },
  twig: {
    before: "<ul>{% for item in items %}<li>{{ item }}</li>{% endfor %}</ul>",
    after: "<ul>{% for item in items %}<li>{{ item }}</li>{% endfor %}</ul>",
  },
  sass: {
    before: "$color: red\n.button\n color: $color",
    after: "$color: red\n.button\n  color: $color",
  },
  less: {
    before: "@color: red;.button{color:@color;}",
    after: "@color: red;\n.button {\n  color: @color;\n}",
  },
  jsonc: {
    before: "{// note\n\"enabled\":true,}",
    after: "{\n  // note\n  \"enabled\": true,\n}",
  },
  json5: {
    before: "{name:'Ada',active:true}",
    after: "{ name: 'Ada', active: true }\n",
  },
  mdx: {
    before: "# Hi\n<div>{value}</div>",
    after: "# Hi\n\n<div>{value}</div>\n",
  },
  graphql: {
    before: "query GetUser{id name posts{title}}",
    after: "query GetUser {\n  id\n  name\n  posts {\n    title\n  }\n}",
    minified: "query GetUser{id name posts{title}}",
  },
  shell: {
    before: "if true; then echo hi; fi",
    after: "if true; then echo hi; fi",
    minified: "if true;then echo hi;fi",
  },
};

const fallback = {
  before: `function ${
    language.replace(/[^a-z]/g, "") || "example"
  }(){return true}`,
  after: `function ${
    language.replace(/[^a-z]/g, "") || "example"
  }() {\n  return true\n}`,
};
const example = examples[language] ?? fallback;
const after = minify
  ? example.minified ?? example.after.replace(/\s+/g, " ").trim()
  : example.after;

const shikiLanguageAliases: Record<string, string> = {
  javascript: "javascript",
  "javascript-biome": "javascript",
  "javascript-oxc": "javascript",
  typescript: "typescript",
  "typescript-biome": "typescript",
  "typescript-oxc": "typescript",
  shell: "bash",
  objectivec: "objective-c",
  objectivecpp: "objective-cpp",
};
const highlightedLanguage = shikiLanguageAliases[language] ?? language;
const highlightOptions = {
  lang: highlightedLanguage,
  theme: "github-dark",
};

function escapeHtml(value: string) {
  return value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

async function highlightCode(value: string) {
  try {
    return await codeToHtml(value, highlightOptions);
  } catch {
    return `<pre class="shiki"><code>${escapeHtml(value)}</code></pre>`;
  }
}

const [beforeHtml, afterHtml] = await Promise.all([
  highlightCode(example.before),
  highlightCode(after),
]);

const relatedLinks = [
  ...(languageConfig?.minify && !minify
    ? [{
      title: `${languageName} Minifier`,
      href: minifierPath,
      description: `Minify ${languageName} locally after formatting.`,
    }]
    : []),
  ...(minify
    ? [{
      title: `${languageName} Formatter`,
      href: formatterPath,
      description: `Format ${languageName} locally before minifying.`,
    }]
    : []),
  ...(language === "json"
    ? [
      {
        title: "JSON Viewer",
        href: "/tools/json-viewer",
        description: "Inspect formatted JSON structure.",
      },
      {
        title: "JSON Diff",
        href: "/tools/json-diff",
        description: "Compare two JSON documents locally.",
      },
      {
        title: "JSON to CSV",
        href: "/tools/json-to-csv",
        description: "Convert arrays of objects into CSV rows.",
      },
    ]
    : []),
  ...(language === "yaml"
    ? [{
      title: "YAML to JSON",
      href: "/tools/yaml-to-json",
      description: "Inspect YAML structure as JSON.",
    }]
    : []),
  ...(language === "toml"
    ? [{
      title: "TOML to JSON",
      href: "/tools/toml-to-json",
      description: "Inspect TOML config as JSON.",
    }]
    : []),
  ...(language === "css"
    ? [{
      title: "CSS Unit Converter",
      href: "/tools/css-unit-converter",
      description: "Convert px, rem, and em values locally.",
    }]
    : []),
].slice(0, 4);
---

<section class="tool-examples border-b border-border bg-background py-10 sm:py-12">
  <div class="mx-auto grid max-w-[1400px] gap-5 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_22rem] lg:px-8">
    <div class="min-w-0 overflow-hidden rounded-lg border border-border bg-card">
      <div class="flex flex-col gap-4 border-b border-border px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
        <div class="min-w-0">
          <h2 class="text-xl font-semibold leading-7 text-foreground sm:text-2xl">
            {minify ? "Minifier example" : "Formatter example"}
          </h2>
          <p class="mt-1 max-w-2xl text-sm leading-6 text-muted-foreground">
            Compare the exact input shape with the cleaned output before opening
            the editor.
          </p>
        </div>
        <div class="flex shrink-0 items-center gap-2 rounded-md border border-border bg-background px-2.5 py-1.5 font-mono text-xs text-muted-foreground">
          <span
            class="h-2 w-2 rounded-full bg-[#14b8a6]"
            aria-hidden="true"
          ></span>
          Local preview
        </div>
      </div>

      <div class="grid min-w-0 gap-px bg-border md:grid-cols-2">
        <article class="min-w-0 bg-card">
          <div class="flex items-center justify-between border-b border-border px-4 py-3">
            <p class="text-sm font-semibold text-foreground">Before</p>
            <span
              class="rounded-sm bg-secondary px-2 py-1 font-mono text-[11px] text-muted-foreground"
            >
              input
            </span>
          </div>
          <div class="min-w-0 bg-[#0d1117]">
            <Fragment set:html={beforeHtml} />
          </div>
        </article>

        <article class="min-w-0 bg-card">
          <div class="flex items-center justify-between border-b border-border px-4 py-3">
            <p class="text-sm font-semibold text-foreground">After</p>
            <span
              class="rounded-sm bg-accent px-2 py-1 font-mono text-[11px] text-accent-foreground"
            >
              {minify ? "minified" : "formatted"}
            </span>
          </div>
          <div class="min-w-0 bg-[#0d1117]">
            <Fragment set:html={afterHtml} />
          </div>
        </article>
      </div>
    </div>

    <aside class="min-w-0 space-y-5">
      <div class="rounded-lg border border-border bg-card p-4">
        <h2 class="text-base font-semibold leading-6 text-foreground">
          Privacy proof
        </h2>
        <div class="mt-3 divide-y divide-border rounded-md border border-border bg-background">
          {["Runs in your browser", "No upload", "No account"].map(item => (
            <div class="flex items-center gap-3 px-3 py-2.5">
              <span
                class="grid h-5 w-5 shrink-0 place-items-center rounded-full bg-accent text-accent-foreground"
              >
                <svg
                  viewBox="0 0 16 16"
                  class="h-3 w-3"
                  aria-hidden="true"
                >
                  <path
                    d="M3.5 8.2 6.4 11 12.5 5"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.8"
                  >
                  </path>
                </svg>
              </span>
              <span class="text-sm text-foreground">{item}</span>
            </div>
          ))}
        </div>
      </div>

      {relatedLinks.length > 0 && (
        <div class="rounded-lg border border-border bg-card p-4">
          <h2 class="text-base font-semibold leading-6 text-foreground">
            Related workflows
          </h2>
          <div class="mt-3 grid gap-2">
            {relatedLinks.map(link => (
              <a
                href={link.href}
                class="group block rounded-md border border-border bg-background p-3 transition-colors duration-150 hover:border-ring hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
              >
                <span class="flex items-center justify-between gap-3">
                  <span class="min-w-0 text-sm font-semibold text-foreground">
                    {link.title}
                  </span>
                  <span
                    class="shrink-0 text-sm text-muted-foreground transition-colors group-hover:text-foreground"
                  >
                    Open
                  </span>
                </span>
                <span
                  class="mt-1 block text-sm leading-6 text-muted-foreground"
                >
                  {link.description}
                </span>
              </a>
            ))}
          </div>
        </div>
      )}
    </aside>
  </div>
</section>

<style>
.tool-examples :global(.shiki) {
  margin: 0;
  min-height: 9rem;
  overflow: auto;
  background: #0d1117 !important;
  padding: 1rem;
  font-size: 0.8125rem;
  line-height: 1.5rem;
}

.tool-examples :global(.shiki code) {
  display: block;
  font-family:
    "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas,
    monospace;
  overflow-wrap: anywhere;
  white-space: pre-wrap;
}

@media (min-width: 768px) {
  .tool-examples :global(.shiki) {
    min-height: 10.5rem;
  }
}
</style>
