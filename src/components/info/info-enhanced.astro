---
import EngineIcon from "@/icons/EngineIcon.astro";
import { LANGUAGES } from "@/lib/languages";
import {
  formatExtensions,
  getFormatterEngineName,
  getLanguageDisplayName,
  getToolModeName,
} from "@/lib/tool-page-seo";

interface VariantData {
  h1?: string;
}

interface Props {
  language: string;
  minify?: boolean;
  variant?: string | null;
  variantData?: VariantData | null;
}

const { language, minify = false, variant, variantData } = Astro.props;

const languageConfig = LANGUAGES[language];
const isMinifier = minify || variant === "minify";
const languageName = getLanguageDisplayName(language, languageConfig);
const modeName = getToolModeName(isMinifier, variant, variantData);
const engineName = getFormatterEngineName(language, isMinifier, variant);
const extensionLabel = languageConfig
  ? formatExtensions(languageConfig)
  : "code snippets";
const actionLabel = isMinifier
  ? "Minify code"
  : modeName.includes("pass") || modeName.includes("Formatter")
  ? `Run ${modeName}`
  : "Format code";
const outputLabel = isMinifier ? "Compact output" : "Readable output";
const outputDetail = isMinifier
  ? "Copy the compact result after checking it still parses as expected."
  : "Move the formatted code back to your editor.";

const notes = [
  {
    label: "Files",
    value: extensionLabel,
    detail: `Paste a ${languageName} snippet or a full source file.`,
  },
  {
    label: "Engine",
    value: engineName,
    detail: isMinifier
      ? "Runs the browser-side minifier for compact output."
      : "Runs the browser-side formatter for readable output.",
  },
  {
    label: "Privacy",
    value: "Local run",
    detail: "The editor does not send pasted code to a formatting API.",
  },
  {
    label: "Result",
    value: outputLabel,
    detail: outputDetail,
  },
];

const checkpoints = [
  {
    label: "Start",
    detail: "Paste a snippet or full file into the editor.",
  },
  {
    label: "Run",
    detail: `Use ${actionLabel} from the action bar.`,
  },
  {
    label: "Review",
    detail: isMinifier
      ? "Check that the compact result is suitable for your target runtime."
      : "Fix syntax issues if processing stops.",
  },
  {
    label: "Move",
    detail: "Use Copy code when the result is ready.",
  },
];
---

<section class="border-b border-border bg-background py-10 sm:py-12">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="min-w-0 overflow-hidden rounded-lg border border-border bg-card">
      <div class="grid gap-6 border-b border-border px-4 py-5 sm:px-5 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.34fr)] lg:items-center">
        <div class="min-w-0 max-w-2xl">
          <p class="text-sm font-medium text-muted-foreground">
            Workflow
          </p>
          <h2 class="mt-2 text-2xl font-semibold leading-tight text-foreground">
            Use {languageName} without sending code.
          </h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            Paste a snippet, run the action, review any highlighted issue, then
            copy the result back to your work.
          </p>
        </div>

        <dl class="grid min-w-0 overflow-hidden rounded-md border border-border bg-border sm:grid-cols-2">
          <div class="bg-background p-3.5">
            <dt class="text-xs font-medium text-muted-foreground">
              Current language
            </dt>
            <dd class="mt-1 truncate text-lg font-semibold leading-tight text-foreground">
              {languageName}
            </dd>
          </div>
          <div class="border-t border-border bg-background p-3.5 sm:border-l sm:border-t-0">
            <dt class="text-xs font-medium text-muted-foreground">
              Current action
            </dt>
            <dd class="mt-1 truncate text-lg font-semibold leading-tight text-foreground">
              {modeName}
            </dd>
          </div>
        </dl>
      </div>

      <ol class="grid min-w-0 divide-y divide-border md:grid-cols-4 md:divide-x md:divide-y-0">
        {checkpoints.map((checkpoint, index) => (
          <li class="min-h-34 px-4 py-4 sm:px-5">
            <span class="font-mono text-xs text-muted-foreground">
              0{index + 1}
            </span>
            <h3 class="mt-3 text-base font-semibold leading-tight text-foreground">
              {checkpoint.label}
            </h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {checkpoint.detail}
            </p>
          </li>
        ))}
      </ol>

      <div class="border-t border-border bg-background px-4 py-4 sm:px-5">
        <dl class="grid min-w-0 overflow-hidden rounded-md border border-border bg-border sm:grid-cols-2 xl:grid-cols-4">
          {notes.map(note => (
            <div class="min-w-0 bg-card p-3.5">
              <dt class="text-xs font-medium text-muted-foreground">
                {note.label}
              </dt>
              <dd class="mt-1 flex min-w-0 items-center gap-2 text-sm font-semibold text-foreground">
                {note.label === "Engine" && (
                  <span
                    class="flex h-6 w-6 shrink-0 items-center justify-center rounded-sm border border-border bg-background text-muted-foreground"
                  >
                    <EngineIcon
                      engine={note.value}
                      class="h-4 w-4"
                      title={`${note.value} engine`}
                    />
                  </span>
                )}
                <span class="truncate">{note.value}</span>
              </dd>
              <dd class="mt-2 text-sm leading-6 text-muted-foreground">
                {note.detail}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>
