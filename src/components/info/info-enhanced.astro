---
import { LANGUAGES } from "@/lib/languages";
import {
  formatExtensions,
  getFormatterEngineName,
  getLanguageDisplayName,
  getToolModeName,
} from "@/lib/tool-page-seo";

interface VariantData {
  h1?: string;
}

interface Props {
  language: string;
  minify?: boolean;
  variant?: string | null;
  variantData?: VariantData | null;
}

const { language, minify = false, variant, variantData } = Astro.props;

const languageConfig = LANGUAGES[language];
const isMinifier = minify || variant === "minify";
const languageName = getLanguageDisplayName(language, languageConfig);
const modeName = getToolModeName(isMinifier, variant, variantData);
const engineName = getFormatterEngineName(language, isMinifier, variant);
const extensionLabel = languageConfig
  ? formatExtensions(languageConfig)
  : "code snippets";
const actionLabel = isMinifier
  ? "Minify code"
  : modeName.includes("pass") || modeName.includes("Formatter")
  ? `Run ${modeName}`
  : "Format code";
const outputLabel = isMinifier ? "Compact output" : "Readable output";
const outputDetail = isMinifier
  ? "Copy the compact result after checking it still parses as expected."
  : "Move the formatted code back to your editor.";

const notes = [
  {
    label: "Files",
    value: extensionLabel,
    detail: `Paste a ${languageName} snippet or a full source file.`,
  },
  {
    label: "Engine",
    value: engineName,
    detail: isMinifier
      ? "Runs the browser-side minifier for compact output."
      : "Runs the browser-side formatter for readable output.",
  },
  {
    label: "Privacy",
    value: "Local run",
    detail: "The editor does not send pasted code to a formatting API.",
  },
  {
    label: "Result",
    value: outputLabel,
    detail: outputDetail,
  },
];

const checkpoints = [
  {
    label: "Start",
    detail: "Paste a snippet or full file into the editor.",
  },
  {
    label: "Run",
    detail: `Use ${actionLabel} from the action bar.`,
  },
  {
    label: "Review",
    detail: isMinifier
      ? "Check that the compact result is suitable for your target runtime."
      : "Fix syntax issues if processing stops.",
  },
  {
    label: "Move",
    detail: "Use Copy code when the result is ready.",
  },
];
---

<section class="border-b border-border bg-card py-14 sm:py-18">
  <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(240px,0.28fr)_minmax(0,1fr)] lg:px-8">
    <aside class="border-y border-border py-6 lg:py-7">
      <p class="text-sm font-medium text-muted-foreground">
        Workflow
      </p>
      <h2 class="mt-4 max-w-sm text-3xl font-semibold leading-tight text-foreground md:text-4xl">
        Use {languageName} without sending code.
      </h2>
      <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
        The page stays centered on the editor: paste, run the action, review the
        output, then copy it back to your work.
      </p>
    </aside>

    <div class="space-y-8">
      <div class="border-y border-border">
        <dl class="grid gap-4 border-b border-border py-5 sm:grid-cols-2">
          <div>
            <dt class="text-sm text-muted-foreground">Current language</dt>
            <dd class="mt-1 text-2xl font-semibold leading-tight">
              {languageName}
            </dd>
          </div>
          <div>
            <dt class="text-sm text-muted-foreground">Current action</dt>
            <dd class="mt-1 text-2xl font-semibold leading-tight">
              {modeName}
            </dd>
          </div>
        </dl>

        <ol class="divide-y divide-border">
          {checkpoints.map((checkpoint) => (
            <li class="grid gap-2 py-4 text-sm leading-6 sm:grid-cols-[160px_1fr] sm:gap-6">
              <span class="font-medium text-foreground">
                {checkpoint.label}
              </span>
              <span class="text-muted-foreground">{checkpoint.detail}</span>
            </li>
          ))}
        </ol>
      </div>

      <div class="divide-y divide-border border-y border-border">
        {notes.map(note => (
          <article class="grid gap-2 py-5 sm:grid-cols-[150px_180px_1fr] sm:items-baseline sm:gap-5">
            <p class="text-sm text-muted-foreground">
              {note.label}
            </p>
            <h3 class="text-base font-semibold text-foreground">
              {note.value}
            </h3>
            <p class="text-sm leading-6 text-muted-foreground">
              {note.detail}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
