---
interface VariantData {
  h1?: string;
}

interface Props {
  language: string;
  variant?: string | null;
  variantData?: VariantData | null;
}

const { language, variant, variantData } = Astro.props;

const languageNames: Record<string, string> = {
  c: "C",
  cpp: "C++",
  csharp: "C#",
  css: "CSS",
  dart: "Dart",
  go: "Go",
  html: "HTML",
  java: "Java",
  javascript: "JavaScript",
  "javascript-biome": "JavaScript Biome",
  json: "JSON",
  lua: "Lua",
  markdown: "Markdown",
  objectivec: "Objective-C",
  objectivecpp: "Objective-C++",
  php: "PHP",
  "php-mago": "PHP Mago",
  proto: "Protocol Buffers",
  python: "Python",
  "python-ruff": "Python Ruff",
  rust: "Rust",
  scss: "SCSS",
  sql: "SQL",
  swift: "Swift",
  toml: "TOML",
  typescript: "TypeScript",
  "typescript-biome": "TypeScript Biome",
  xml: "XML",
  yaml: "YAML",
  zig: "Zig",
};

const modeNames: Record<string, string> = {
  beautifier: "Beautifier",
  biome: "Biome pass",
  free: "Formatter",
  minify: "Minifier",
  online: "Formatter",
  pretty: "Pretty printer",
  prettify: "Pretty printer",
  private: "Private formatter",
  ruff: "Ruff pass",
  secure: "Private formatter",
};

const getLanguageName = (value: string) => {
  if (languageNames[value]) {
    return languageNames[value];
  }

  return value
    .split("-")
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
};

const getModeName = (
  variantValue: string | null | undefined,
  data: VariantData | null | undefined,
) => {
  if (variantValue && modeNames[variantValue]) {
    return modeNames[variantValue];
  }

  if (data?.h1) {
    const compactName = data.h1
      .replace(/online/gi, "")
      .replace(/free/gi, "")
      .trim();

    return compactName || "Formatter";
  }

  return "Formatter";
};

const languageName = getLanguageName(language);
const modeName = getModeName(variant, variantData);
const actionLabel = modeName === "Minifier"
  ? "Minify code"
  : modeName.includes("pass")
  ? `Run ${modeName}`
  : "Format code";

const notes = [
  {
    label: "Input",
    value: "Paste code",
    detail: "Use a snippet or a full file.",
  },
  {
    label: "Format",
    value: modeName,
    detail: "Clean indentation, spacing, and line breaks.",
  },
  {
    label: "Issues",
    value: "Highlighted lines",
    detail: "If formatting stops, fix the shown line and try again.",
  },
  {
    label: "Result",
    value: "Copy output",
    detail: "Move the formatted code back to your editor.",
  },
];

const checkpoints = [
  {
    label: "Start",
    detail: "Paste a snippet or full file into the editor.",
  },
  {
    label: "Run",
    detail: `Use ${actionLabel} from the action bar.`,
  },
  {
    label: "Review",
    detail: "Fix syntax issues if processing stops.",
  },
  {
    label: "Move",
    detail: "Use Copy code when the result is ready.",
  },
];
---

<section class="border-b border-border bg-background py-10 sm:py-12">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="min-w-0 overflow-hidden rounded-lg border border-border bg-card">
      <div class="grid gap-6 border-b border-border px-4 py-5 sm:px-5 lg:grid-cols-[minmax(0,1fr)_minmax(320px,0.34fr)] lg:items-center">
        <div class="min-w-0 max-w-2xl">
          <p class="text-sm font-medium text-muted-foreground">
            Workflow
          </p>
          <h2 class="mt-2 text-2xl font-semibold leading-tight text-foreground">
            Use {languageName} without sending code.
          </h2>
          <p class="mt-3 text-sm leading-6 text-muted-foreground">
            Paste a snippet, run the action, review any highlighted issue, then
            copy the result back to your work.
          </p>
        </div>

        <dl class="grid min-w-0 overflow-hidden rounded-md border border-border bg-border sm:grid-cols-2">
          <div class="bg-background p-3.5">
            <dt class="text-xs font-medium text-muted-foreground">
              Current language
            </dt>
            <dd class="mt-1 truncate text-lg font-semibold leading-tight text-foreground">
              {languageName}
            </dd>
          </div>
          <div class="border-t border-border bg-background p-3.5 sm:border-l sm:border-t-0">
            <dt class="text-xs font-medium text-muted-foreground">
              Current action
            </dt>
            <dd class="mt-1 truncate text-lg font-semibold leading-tight text-foreground">
              {modeName}
            </dd>
          </div>
        </dl>
      </div>

      <ol class="grid min-w-0 divide-y divide-border md:grid-cols-4 md:divide-x md:divide-y-0">
        {checkpoints.map((checkpoint, index) => (
          <li class="min-h-34 px-4 py-4 sm:px-5">
            <span class="font-mono text-xs text-muted-foreground">
              0{index + 1}
            </span>
            <h3 class="mt-3 text-base font-semibold leading-tight text-foreground">
              {checkpoint.label}
            </h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {checkpoint.detail}
            </p>
          </li>
        ))}
      </ol>

      <div class="border-t border-border bg-background px-4 py-4 sm:px-5">
        <dl class="grid min-w-0 overflow-hidden rounded-md border border-border bg-border sm:grid-cols-2 xl:grid-cols-4">
          {notes.map(note => (
            <div class="min-w-0 bg-card p-3.5">
              <dt class="text-xs font-medium text-muted-foreground">
                {note.label}
              </dt>
              <dd class="mt-1 truncate text-sm font-semibold text-foreground">
                {note.value}
              </dd>
              <dd class="mt-2 text-sm leading-6 text-muted-foreground">
                {note.detail}
              </dd>
            </div>
          ))}
        </dl>
      </div>
    </div>
  </div>
</section>
