---
interface VariantData {
  h1?: string;
}

interface Props {
  language: string;
  variant?: string | null;
  variantData?: VariantData | null;
}

const { language, variant, variantData } = Astro.props;

const languageNames: Record<string, string> = {
  c: "C",
  cpp: "C++",
  csharp: "C#",
  css: "CSS",
  dart: "Dart",
  go: "Go",
  html: "HTML",
  java: "Java",
  javascript: "JavaScript",
  "javascript-biome": "JavaScript Biome",
  json: "JSON",
  lua: "Lua",
  markdown: "Markdown",
  objectivec: "Objective-C",
  objectivecpp: "Objective-C++",
  php: "PHP",
  "php-mago": "PHP Mago",
  proto: "Protocol Buffers",
  python: "Python",
  "python-ruff": "Python Ruff",
  rust: "Rust",
  scss: "SCSS",
  sql: "SQL",
  swift: "Swift",
  toml: "TOML",
  typescript: "TypeScript",
  "typescript-biome": "TypeScript Biome",
  xml: "XML",
  yaml: "YAML",
  zig: "Zig",
};

const modeNames: Record<string, string> = {
  beautifier: "Beautifier",
  biome: "Biome pass",
  free: "Formatter",
  minify: "Minifier",
  online: "Formatter",
  pretty: "Pretty printer",
  prettify: "Pretty printer",
  private: "Private formatter",
  ruff: "Ruff pass",
  secure: "Private formatter",
};

const getLanguageName = (value: string) => {
  if (languageNames[value]) {
    return languageNames[value];
  }

  return value
    .split("-")
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
};

const getModeName = (
  variantValue: string | null | undefined,
  data: VariantData | null | undefined,
) => {
  if (variantValue && modeNames[variantValue]) {
    return modeNames[variantValue];
  }

  if (data?.h1) {
    const compactName = data.h1
      .replace(/online/gi, "")
      .replace(/free/gi, "")
      .trim();

    return compactName || "Formatter";
  }

  return "Formatter";
};

const languageName = getLanguageName(language);
const modeName = getModeName(variant, variantData);
const actionLabel = modeName === "Minifier"
  ? "Minify code"
  : modeName.includes("pass")
  ? `Run ${modeName}`
  : "Format code";

const notes = [
  {
    label: "Input",
    value: "Paste code",
    detail: "Use a snippet or a full file.",
  },
  {
    label: "Format",
    value: modeName,
    detail: "Clean indentation, spacing, and line breaks.",
  },
  {
    label: "Issues",
    value: "Highlighted lines",
    detail: "If formatting stops, fix the shown line and try again.",
  },
  {
    label: "Result",
    value: "Copy output",
    detail: "Move the formatted code back to your editor.",
  },
];

const checkpoints = [
  {
    label: "Start",
    detail: "Paste a snippet or full file into the editor.",
  },
  {
    label: "Run",
    detail: `Use ${actionLabel} from the action bar.`,
  },
  {
    label: "Review",
    detail: "Fix syntax issues if processing stops.",
  },
  {
    label: "Move",
    detail: "Use Copy code when the result is ready.",
  },
];
---

<section class="border-b border-border bg-card py-14 sm:py-18">
  <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(240px,0.28fr)_minmax(0,1fr)] lg:px-8">
    <aside class="border-y border-border py-6 lg:py-7">
      <p class="text-sm font-medium text-muted-foreground">
        Workflow
      </p>
      <h2 class="mt-4 max-w-sm text-3xl font-semibold leading-tight text-foreground md:text-4xl">
        Use {languageName} without sending code.
      </h2>
      <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
        The page stays centered on the editor: paste, run the action, review the
        output, then copy it back to your work.
      </p>
    </aside>

    <div class="space-y-8">
      <div class="border-y border-border">
        <dl class="grid gap-4 border-b border-border py-5 sm:grid-cols-2">
          <div>
            <dt class="text-sm text-muted-foreground">Current language</dt>
            <dd class="mt-1 text-2xl font-semibold leading-tight">
              {languageName}
            </dd>
          </div>
          <div>
            <dt class="text-sm text-muted-foreground">Current action</dt>
            <dd class="mt-1 text-2xl font-semibold leading-tight">
              {modeName}
            </dd>
          </div>
        </dl>

        <ol class="divide-y divide-border">
          {checkpoints.map((checkpoint) => (
            <li class="grid gap-2 py-4 text-sm leading-6 sm:grid-cols-[160px_1fr] sm:gap-6">
              <span class="font-medium text-foreground">
                {checkpoint.label}
              </span>
              <span class="text-muted-foreground">{checkpoint.detail}</span>
            </li>
          ))}
        </ol>
      </div>

      <div class="divide-y divide-border border-y border-border">
        {notes.map(note => (
          <article class="grid gap-2 py-5 sm:grid-cols-[150px_180px_1fr] sm:items-baseline sm:gap-5">
            <p class="text-sm text-muted-foreground">
              {note.label}
            </p>
            <h3 class="text-base font-semibold text-foreground">
              {note.value}
            </h3>
            <p class="text-sm leading-6 text-muted-foreground">
              {note.detail}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
