---
interface VariantData {
  h1?: string;
}

interface Props {
  language: string;
  variant?: string | null;
  variantData?: VariantData | null;
}

const { language, variant, variantData } = Astro.props;

const languageNames: Record<string, string> = {
  c: "C",
  cpp: "C++",
  csharp: "C#",
  css: "CSS",
  dart: "Dart",
  go: "Go",
  html: "HTML",
  java: "Java",
  javascript: "JavaScript",
  "javascript-biome": "JavaScript Biome",
  json: "JSON",
  lua: "Lua",
  markdown: "Markdown",
  objectivec: "Objective-C",
  objectivecpp: "Objective-C++",
  php: "PHP",
  "php-mago": "PHP Mago",
  proto: "Protocol Buffers",
  python: "Python",
  "python-ruff": "Python Ruff",
  rust: "Rust",
  scss: "SCSS",
  sql: "SQL",
  swift: "Swift",
  toml: "TOML",
  typescript: "TypeScript",
  "typescript-biome": "TypeScript Biome",
  xml: "XML",
  yaml: "YAML",
  zig: "Zig",
};

const modeNames: Record<string, string> = {
  beautifier: "Beautifier",
  biome: "Biome pass",
  free: "Formatter",
  minify: "Minifier",
  online: "Formatter",
  pretty: "Pretty printer",
  prettify: "Pretty printer",
  private: "Private formatter",
  ruff: "Ruff pass",
  secure: "Private formatter",
  validator: "Validator",
};

const getLanguageName = (value: string) => {
  if (languageNames[value]) {
    return languageNames[value];
  }

  return value
    .split("-")
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
};

const getModeName = (
  variantValue: string | null | undefined,
  data: VariantData | null | undefined,
) => {
  if (variantValue && modeNames[variantValue]) {
    return modeNames[variantValue];
  }

  if (data?.h1) {
    const compactName = data.h1
      .replace(/online/gi, "")
      .replace(/free/gi, "")
      .trim();

    return compactName || "Formatter";
  }

  return "Formatter";
};

const languageName = getLanguageName(language);
const modeName = getModeName(variant, variantData);

const notes = [
  {
    label: "Input",
    value: "Paste code",
    detail: "Use a snippet or a full file.",
  },
  {
    label: "Format",
    value: modeName,
    detail: "Clean indentation, spacing, and line breaks.",
  },
  {
    label: "Issues",
    value: "Highlighted lines",
    detail: "If formatting stops, fix the shown line and try again.",
  },
  {
    label: "Result",
    value: "Copy output",
    detail: "Move the formatted code back to your editor.",
  },
];

const checkpoints = [
  "Paste your code.",
  `Click ${modeName}.`,
  "Fix highlighted issues if formatting stops.",
  "Copy the formatted result.",
];
---

<section class="border-b border-border bg-card py-16 sm:py-20">
  <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(240px,0.28fr)_minmax(0,1fr)] lg:px-8">
    <aside class="border-y border-border py-6 lg:py-7">
      <p class="font-mono text-xs uppercase text-muted-foreground">
        Notes
      </p>
      <h2 class="mt-5 max-w-sm text-4xl font-semibold leading-none text-foreground md:text-5xl">
        Format {languageName}.
      </h2>
      <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
        Paste code, clean it up, and copy the formatted result.
      </p>
    </aside>

    <div class="space-y-8">
      <div class="grid overflow-hidden rounded-lg border border-border bg-background md:grid-cols-[0.95fr_1.05fr]">
        <div class="border-b border-border p-5 md:border-b-0 md:border-r">
          <p class="font-mono text-xs uppercase text-muted-foreground">
            Tool
          </p>
          <div class="mt-8 grid gap-4 sm:grid-cols-2">
            <div>
              <p class="text-sm text-muted-foreground">Language</p>
              <p class="mt-1 text-2xl font-semibold leading-tight">
                {languageName}
              </p>
            </div>
            <div>
              <p class="text-sm text-muted-foreground">Mode</p>
              <p class="mt-1 text-2xl font-semibold leading-tight">
                {modeName}
              </p>
            </div>
          </div>
        </div>

        <ol class="divide-y divide-border">
          {checkpoints.map((checkpoint, index) => (
            <li class="grid grid-cols-[48px_1fr] items-start gap-3 p-4 text-sm leading-6">
              <span class="font-mono text-xs text-muted-foreground">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span>{checkpoint}</span>
            </li>
          ))}
        </ol>
      </div>

      <div class="divide-y divide-border border-y border-border">
        {notes.map(note => (
          <article class="grid gap-3 py-5 sm:grid-cols-[150px_160px_1fr] sm:items-baseline">
            <p class="font-mono text-xs uppercase text-muted-foreground">
              {note.label}
            </p>
            <h3 class="text-base font-semibold text-foreground">
              {note.value}
            </h3>
            <p class="text-sm leading-6 text-muted-foreground">
              {note.detail}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
