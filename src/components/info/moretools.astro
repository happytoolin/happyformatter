const utilityFamilies: ToolFamily[] = UTILITY_CATEGORIES.map(category => ({
  name: category.name,
  initials: category.shortName.slice(0, 2).toUpperCase(),
  group: "Utilities",
  descriptor: category.shortName,
  actions: getUtilityToolsByCategory(category.id).map(tool => ({
    label: tool.name,
    url: `/tools/${tool.slug}`,
    type: "UTIL",
  })),
}));

const directoryFamilies = [...toolFamilies, ...utilityFamilies];
const groupOrder: ToolFamily["group"][] = [
  "Web",
  "Data",
  "Runtime",
  "Systems",
  "Utilities",
];
const sections = groupOrder.map((group) => ({
  group,
  id: `tools-${group.toLowerCase()}`,
  families: directoryFamilies.filter((family) => family.group === group),
}));

const allActions = directoryFamilies.flatMap((family) => family.actions);
const minifierCount =
  allActions.filter((action) => action.type === "MIN").length;

const typeLabel: Record<ToolType, string> = {
  FMT: "Format",
  MIN: "Minify",
  UTIL: "Open",
};

const getActionText = (family: ToolFamily, action: ToolAction) => {
  if (action.label === "Biome") {
    return action.type === "MIN" ? "Minify with Biome" : "Format with Biome";
  }

  if (action.label === "Ruff") {
    return "Format with Ruff";
  }

  if (action.label === "Mago") {
    return "Format with Mago";
  }

  if (action.label === "Objective-C++") {
    return "Format Objective-C++";
  }

  if (action.type === "UTIL") {
    return action.label;
  }

  return `${typeLabel[action.type]} ${family.name}`;
};
---

<section
  class="border-t border-border bg-background py-16 sm:py-20"
  id="more-tools"
>
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[minmax(240px,330px)_minmax(0,1fr)]">
      <aside class="self-start lg:sticky lg:top-24">
        <div class="border-y border-border py-6">
          <p class="text-sm font-medium text-muted-foreground">
            Directory
          </p>
          <h2 class="mt-4 max-w-sm text-3xl font-semibold leading-tight text-foreground md:text-4xl">
            Find another tool.
          </h2>
          <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
            {allActions.length} routes are grouped by file type and workflow.
            {minifierCount}
            {" "}of them open a minifier.
          </p>

          <nav
            class="mt-5 flex flex-wrap gap-2"
            aria-label="Tool directory groups"
          >
            {sections.map((section) => (
              <a
                href={`#${section.id}`}
                class="rounded-md border border-border bg-card px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
              >
                {section.group}
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <div class="space-y-10">
        {sections.map((section) => (
          <section id={section.id} aria-labelledby={`${section.id}-heading`}>
            <div class="mb-3 flex items-end justify-between gap-4 border-b border-border pb-3">
              <h3
                id={`${section.id}-heading`}
                class="text-xl font-semibold text-foreground"
              >
                {section.group}
              </h3>
              <span class="text-sm text-muted-foreground">
                {section.families.length} families
              </span>
            </div>

            <div class="divide-y divide-border border-b border-border">
              {section.families.map((family) => (
                <article class="grid gap-4 py-4 md:grid-cols-[minmax(190px,0.38fr)_minmax(0,1fr)] md:items-center">
                  <a
                    href={family.actions[0].url}
                    data-tool-action
                    aria-label={`Open ${family.name} ${typeLabel[family.actions[0].type].toLowerCase()} tool`}
                    class="-m-2 flex min-w-0 items-center gap-3 rounded-md p-2 transition-colors hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                  >
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border bg-card">
                      {family.icon
                        ? <LanguageIcon icon={family.icon} class="h-6 w-6" />
                        : (
                          <span class="text-sm font-semibold text-foreground">
                            {family.initials}
                          </span>
                        )}
                    </div>
                    <div class="min-w-0">
                      <h4 class="truncate text-base font-medium text-foreground">
                        {family.name}
                      </h4>
                      <p class="mt-1 text-sm text-muted-foreground">
                        {family.descriptor}
                      </p>
                    </div>
                  </a>

                  <div class="flex flex-wrap gap-2 md:justify-end">
                    {family.actions.map((action) => (
                      <a
                        href={action.url}
                        data-tool-action
                        class="group/action inline-flex min-h-9 items-center gap-2 rounded-md border border-border bg-card px-3 py-2 text-sm font-medium text-foreground transition-[background-color,border-color,color,transform] duration-150 ease-out hover:border-foreground hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring active:translate-y-px motion-reduce:transition-none"
                      >
                        <span>{getActionText(family, action)}</span>
                      </a>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const tools = document.querySelectorAll("[data-tool-action]");
  tools.forEach((tool) => {
    const toolName = tool.getAttribute("href")?.replace(/^\//, "") || "";

    tool.addEventListener("click", () => {
      if (typeof window.gtag === "function") {
        window.gtag("event", `Click ${toolName}`, {
          "event_category": "Tool Interaction",
          "value": toolName,
        });
      }
    });
  });
});
</script>
