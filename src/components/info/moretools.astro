const utilityCategoryIcons: Record<UtilityToolCategoryId, string> = {
  colors: "colors",
  converters: "converters",
  css: "css-tools",
  json: "json-tools",
  markup: "markup",
  security: "security",
  text: "text",
  time: "time",
  web: "web",
};

const utilityToolIcons: Record<string, string> = {
  "base64-encode-decode": "base64",
  "color-converter": "colors",
  "cron-expression-explainer": "cron",
  "css-unit-converter": "css-tools",
  "csv-to-json": "csv",
  "csv-tsv-converter": "csv",
  "hash-generator": "hash",
  "html-entity-encode-decode": "html-entities",
  "http-header-parser": "headers",
  "json-diff": "diff",
  "json-sort-keys": "json",
  "json-to-csv": "csv",
  "json-to-toml": "converters",
  "json-to-yaml": "converters",
  "json-viewer": "viewer",
  "jwt-decoder": "jwt",
  "markdown-preview": "viewer",
  "markdown-to-html": "markup",
  "query-string-parser": "query",
  "regex-tester": "regex",
  "string-escape-unescape": "string",
  "svg-optimizer-pretty-printer": "svg",
  "text-case-converter": "case",
  "toml-to-json": "converters",
  "unix-timestamp-converter": "timestamp",
  "uuid-generator": "fingerprint",
  "xml-to-json": "converters",
  "yaml-to-json": "converters",
};

const utilityFamilies: ToolFamily[] = UTILITY_CATEGORIES.map(category => ({
  name: category.name,
  initials: category.shortName.slice(0, 2).toUpperCase(),
  utilityIcon: utilityCategoryIcons[category.id],
  group: "Utilities",
  descriptor: category.shortName,
  actions: getUtilityToolsByCategory(category.id).map(tool => ({
    icon: utilityToolIcons[tool.slug] ?? utilityCategoryIcons[category.id],
    label: tool.name,
    url: `/tools/${tool.slug}`,
    type: "UTIL",
  })),
}));

const directoryFamilies = [...toolFamilies, ...utilityFamilies];
const groupOrder: ToolFamily["group"][] = [
  "Web",
  "Data",
  "Runtime",
  "Systems",
  "Utilities",
];
const sections = groupOrder.map((group) => ({
  group,
  id: `tools-${group.toLowerCase()}`,
  families: directoryFamilies.filter((family) => family.group === group),
}));

const allActions = directoryFamilies.flatMap((family) => family.actions);
const minifierCount =
  allActions.filter((action) => action.type === "MIN").length;

const typeLabel: Record<ToolType, string> = {
  FMT: "Format",
  MIN: "Minify",
  UTIL: "Open",
};

const genericActionLabels = new Set(["Format", "Minify"]);
const engineActionLabels = new Set(["Biome", "Mago", "OXC", "Ruff"]);

const getActionEngineName = (action: ToolAction) =>
  engineActionLabels.has(action.label) ? action.label : null;

const getActionLanguageIcon = (family: ToolFamily, action: ToolAction) => {
  if (action.type === "UTIL" || getActionEngineName(action)) {
    return null;
  }

  if (genericActionLabels.has(action.label)) {
    return family.icon ?? null;
  }

  const actionId = action.url.split("/").filter(Boolean).at(-1);
  return action.icon ?? actionId ?? family.icon ?? null;
};

const getActionText = (family: ToolFamily, action: ToolAction) => {
  if (action.type === "UTIL") {
    return action.label;
  }

  if (!genericActionLabels.has(action.label)) {
    if (action.label === "Objective-C++") {
      return "Format Objective-C++";
    }

    return `${typeLabel[action.type]} with ${action.label}`;
  }

  return `${typeLabel[action.type]} ${family.name}`;
};
---

<section
  class="border-t border-border bg-background py-16 sm:py-20"
  id="more-tools"
>
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[minmax(240px,330px)_minmax(0,1fr)]">
      <aside class="self-start lg:sticky lg:top-24">
        <div class="border-y border-border py-6">
          <p class="text-sm font-medium text-muted-foreground">
            Directory
          </p>
          <h2 class="mt-4 max-w-sm text-3xl font-semibold leading-tight text-foreground md:text-4xl">
            Find another tool.
          </h2>
          <p class="mt-5 max-w-sm text-sm leading-6 text-muted-foreground">
            {allActions.length} routes are grouped by file type and workflow.
            {minifierCount}
            {" "}of them open a minifier.
          </p>

          <nav
            class="mt-5 flex flex-wrap gap-2"
            aria-label="Tool directory groups"
          >
            {sections.map((section) => (
              <a
                href={`#${section.id}`}
                class="rounded-md border border-border bg-card px-3 py-2 text-sm text-muted-foreground transition-colors hover:border-foreground hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
              >
                {section.group}
              </a>
            ))}
          </nav>
        </div>
      </aside>

      <div class="space-y-10">
        {sections.map((section) => (
          <section id={section.id} aria-labelledby={`${section.id}-heading`}>
            <div class="mb-3 flex items-end justify-between gap-4 border-b border-border pb-3">
              <h3
                id={`${section.id}-heading`}
                class="text-xl font-semibold text-foreground"
              >
                {section.group}
              </h3>
              <span class="text-sm text-muted-foreground">
                {section.families.length} families
              </span>
            </div>

            <div class="divide-y divide-border border-b border-border">
              {section.families.map((family) => (
                <article class="grid gap-4 py-4 md:grid-cols-[minmax(190px,0.38fr)_minmax(0,1fr)] md:items-center">
                  <a
                    href={family.actions[0].url}
                    data-tool-action
                    aria-label={`Open ${family.name} ${typeLabel[family.actions[0].type].toLowerCase()} tool`}
                    class="-m-2 flex min-w-0 items-center gap-3 rounded-md p-2 transition-colors hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                  >
                    <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-md border border-border bg-card">
                      {family.icon
                        ? <LanguageIcon icon={family.icon} class="h-6 w-6" />
                        : family.utilityIcon
                        ? (
                          <UtilityIcon
                            icon={family.utilityIcon}
                            class="h-5 w-5 text-foreground"
                            title={family.name}
                          />
                        )
                        : (
                          <span class="text-sm font-semibold text-foreground">
                            {family.initials}
                          </span>
                        )}
                    </div>
                    <div class="min-w-0">
                      <div class="flex min-w-0 flex-wrap items-center gap-2">
                        <h4 class="truncate text-base font-medium text-foreground">
                          {family.name}
                        </h4>
                        {family.tag && (
                          <span
                            class="new-tool-badge inline-flex items-center gap-1 rounded-full border px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide"
                          >
                            <svg
                              xmlns="http://www.w3.org/2000/svg"
                              width="11"
                              height="11"
                              viewBox="0 0 24 24"
                              fill="currentColor"
                              aria-hidden="true"
                              class="new-tool-badge__star"
                            >
                              <path d="m12 2 2.9 6.2 6.7.8-4.9 4.6 1.3 6.6-6-3.3-6 3.3 1.3-6.6L2.4 9l6.7-.8L12 2Z" />
                            </svg>
                            <span class="new-tool-badge__label">
                              {family.tag}
                            </span>
                          </span>
                        )}
                      </div>
                      <p class="mt-1 text-sm text-muted-foreground">
                        {family.descriptor}
                      </p>
                    </div>
                  </a>

                  <div class="flex flex-wrap gap-2 md:justify-end">
                    {family.actions.map((action) => {
                      const actionEngineName = getActionEngineName(action);
                      const actionLanguageIcon = getActionLanguageIcon(
                        family,
                        action,
                      );

                      return (
                        <a
                          href={action.url}
                          data-tool-action
                          class="group/action inline-flex min-h-9 max-w-full items-center gap-2 rounded-md border border-border bg-card px-3 py-2 text-sm font-medium text-foreground transition-[background-color,border-color,color,transform] duration-150 ease-out hover:border-foreground hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring active:translate-y-px motion-reduce:transition-none"
                        >
                          {action.icon && (
                            <UtilityIcon
                              icon={action.icon}
                              class="h-4 w-4 shrink-0 text-muted-foreground transition-colors group-hover/action:text-foreground"
                              title={action.label}
                            />
                          )}
                          {!action.icon && actionEngineName && (
                            <EngineIcon
                              engine={actionEngineName}
                              class="h-4 w-4 shrink-0 text-muted-foreground transition-colors group-hover/action:text-foreground"
                              title={action.label}
                            />
                          )}
                          {!action.icon && actionLanguageIcon && (
                            <LanguageIcon
                              icon={actionLanguageIcon}
                              class="h-4 w-4 shrink-0"
                              title={action.label}
                            />
                          )}
                          <span class="truncate">
                            {getActionText(family, action)}
                          </span>
                        </a>
                      );
                    })}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const tools = document.querySelectorAll("[data-tool-action]");
  tools.forEach((tool) => {
    const toolName = tool.getAttribute("href")?.replace(/^\//, "") || "";

    tool.addEventListener("click", () => {
      if (typeof window.gtag === "function") {
        window.gtag("event", `Click ${toolName}`, {
          "event_category": "Tool Interaction",
          "value": toolName,
        });
      }
    });
  });
});
</script>

<style>
.new-tool-badge {
  position: relative;
  overflow: hidden;
  border-color: color-mix(in srgb, #d8a21b 58%, var(--border));
  background:
    linear-gradient(
      135deg,
      rgba(255, 244, 184, 0.98),
      rgba(235, 172, 32, 0.82)
    ),
    var(--secondary);
  color: #5c3d00;
  box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62);
  animation: new-tool-glow 2.8s ease-out infinite;
}

.new-tool-badge::after {
  position: absolute;
  z-index: 0;
  inset: -30% auto -30% -45%;
  width: 42%;
  content: "";
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.7),
    transparent
  );
  transform: rotate(18deg) translateX(-120%);
  animation: new-tool-shine 3.6s ease-out infinite;
}

.new-tool-badge__star {
  position: relative;
  z-index: 1;
  filter: drop-shadow(0 0 4px rgba(194, 126, 0, 0.45));
  animation: new-tool-star 1.8s ease-out infinite;
}

.new-tool-badge__label {
  position: relative;
  z-index: 1;
}

@keyframes new-tool-glow {
  0%,
  100% {
    border-color: color-mix(in srgb, #d8a21b 58%, var(--border));
  }
  45% {
    border-color: #f4c64c;
  }
}

@keyframes new-tool-shine {
  0%,
  58% {
    transform: rotate(18deg) translateX(-120%);
  }
  82%,
  100% {
    transform: rotate(18deg) translateX(360%);
  }
}

@keyframes new-tool-star {
  0%,
  100% {
    transform: scale(1) rotate(0deg);
  }
  42% {
    transform: scale(1.14) rotate(9deg);
  }
}

@media (prefers-reduced-motion: reduce) {
  .new-tool-badge,
  .new-tool-badge::after,
  .new-tool-badge__star {
    animation: none;
  }
}
</style>
