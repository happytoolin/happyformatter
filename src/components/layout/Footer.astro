---
import { withTrailingSlash } from "@/lib/canonical-url";

const footerLinks = [
  { label: "About", href: withTrailingSlash("/about") },
  { label: "Privacy", href: withTrailingSlash("/privacy-policy") },
  { label: "Terms", href: withTrailingSlash("/terms-of-service") },
  { label: "Security", href: withTrailingSlash("/security") },
  { label: "Contact", href: withTrailingSlash("/contact") },
];
---

<footer class="border-t border-border bg-card py-8">
  <div class="mx-auto flex max-w-[1400px] flex-col gap-6 px-4 sm:px-6 md:flex-row md:items-center md:justify-between lg:px-8">
    <div class="min-w-0">
      <div class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-sm font-semibold text-foreground">
        HappyFormatter
        <span class="font-normal text-muted-foreground">by</span>
        <a
          href="https://happytoolin.com"
          target="_blank"
          rel="noopener noreferrer"
          class="transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          HappyToolin
        </a>
      </div>
      <div class="mt-1 font-mono text-[11px] text-muted-foreground">
        {new Date().getFullYear()} / client-side developer tools
      </div>
    </div>

    <nav class="flex flex-wrap items-center gap-x-5 gap-y-3 text-sm text-muted-foreground">
      {footerLinks.map(link => (
        <a
          href={link.href}
          class="transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://happytokenizer.com"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        HappyTokenizer
      </a>
    </nav>
  </div>
</footer>
