---
import { LANGUAGES } from "@/lib/languages";

interface Props {
  language: string;
  minify: boolean;
}

const { language, minify } = Astro.props;
const languageName = LANGUAGES[language]?.name
  || language
    .split("-")
    .map(part => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
const title = language === "privacy"
  ? "Privacy Policy"
  : language === "terms"
  ? "Terms of Service"
  : `${languageName} Formatter${minify ? " & Minifier" : ""}`;
---

<section class="border-b border-border bg-background">
  <div class="mx-auto max-w-[1400px] px-4 py-5 sm:px-6 lg:px-8 lg:py-6">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div class="min-w-0">
        <p class="font-mono text-xs uppercase text-muted-foreground">
          Formatter
        </p>
        <h1 class="mt-1 max-w-5xl text-2xl font-semibold leading-tight text-foreground sm:text-3xl">
          {title}
        </h1>
      </div>

      <div class="flex flex-wrap gap-2">
        <span
          class="rounded-md border border-border bg-card px-3 py-2 font-mono text-xs uppercase text-muted-foreground"
        >
          {minify ? "Format + minify" : "Format"}
        </span>
        <span
          class="rounded-md border border-border bg-card px-3 py-2 font-mono text-xs uppercase text-muted-foreground"
        >
          No sign in
        </span>
      </div>
    </div>
  </div>
</section>
