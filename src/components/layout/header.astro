---
import Icon from "../../icons/Icons.astro";
import Logo from "../../icons/Logo.astro";
import ThemeIcon from "../ThemeIcon.astro";

const primaryLinks = [
  { label: "JSON", href: "/json" },
  { label: "JavaScript", href: "/javascript" },
  { label: "CSS", href: "/css" },
  { label: "SQL", href: "/sql" },
  { label: "Python", href: "/python" },
];
---

<header class="sticky top-0 z-40 w-full border-b border-border bg-background">
  <div class="mx-auto flex h-16 max-w-[1400px] items-center justify-between px-4 sm:px-6 lg:px-8">
    <a
      href="/"
      class="group inline-flex items-center gap-3 rounded-md text-foreground transition-opacity hover:opacity-80"
      aria-label="HappyFormatter home"
    >
      <Logo class="h-8 w-8" />
      <div class="flex flex-col leading-none">
        <span class="text-base font-semibold">HappyFormatter</span>
        <span class="mt-1 text-xs text-muted-foreground">
          Local code tools
        </span>
      </div>
    </a>

    <nav
      class="hidden items-center gap-1 md:flex"
      aria-label="Primary language navigation"
    >
      {primaryLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-md px-3 py-2 text-sm text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
          aria-label={`Open ${link.label} formatter`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="#more-tools"
        class="hf-button hf-button-outline hf-button-md hidden md:inline-flex"
      >
        Browse tools
      </a>
      <ThemeIcon />
      <button
        id="menu-button"
        class="hf-button hf-button-outline hf-button-icon md:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open navigation menu"
        title="Open navigation menu"
      >
        <span class="[&>svg]:h-4 [&>svg]:w-4" aria-hidden="true">
          <Icon icon="menu" />
        </span>
      </button>
    </div>
  </div>
</header>

<div
  class="fixed inset-0 z-50 hidden bg-background"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  aria-labelledby="mobile-menu-title"
  id="mobile-menu"
  hidden
>
  <div class="flex min-h-[100dvh] flex-col">
    <div class="flex h-16 items-center justify-between border-b border-border px-4">
      <h2 id="mobile-menu-title" class="sr-only">Navigation Menu</h2>
      <a href="/" class="inline-flex items-center gap-3">
        <Logo class="h-8 w-8" />
        <span class="text-base font-semibold">HappyFormatter</span>
      </a>
      <button
        type="button"
        class="hf-button hf-button-outline hf-button-icon"
        id="close-menu-button"
        aria-label="Close navigation menu"
        title="Close navigation menu"
      >
        <span class="[&>svg]:h-4 [&>svg]:w-4" aria-hidden="true">
          <Icon icon="cross" />
        </span>
      </button>
    </div>

    <nav
      class="grid gap-px border-b border-border bg-border"
      aria-label="Mobile language navigation"
    >
      {primaryLinks.map((link) => (
        <a
          href={link.href}
          class="bg-background px-4 py-4 text-lg font-medium text-foreground transition-colors hover:bg-secondary"
          aria-label={`Open ${link.label} formatter`}
        >
          {link.label}
        </a>
      ))}
      <a
        href="#more-tools"
        class="bg-background px-4 py-4 text-lg font-medium text-foreground transition-colors hover:bg-secondary"
      >
        All tools
      </a>
    </nav>

    <div class="mt-auto flex items-center justify-between px-4 py-5">
      <span class="font-mono text-xs text-muted-foreground"
      >Client-side formatting</span>
      <ThemeIcon />
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const menuButton = document.getElementById("menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const closeMenuButton = document.getElementById("close-menu-button");
  let previousBodyOverflow = "";

  function isMenuOpen() {
    return Boolean(mobileMenu && !mobileMenu.hidden);
  }

  function getFocusableMenuItems(): HTMLElement[] {
    if (!mobileMenu) {
      return [];
    }

    return Array.from(
      mobileMenu.querySelectorAll<HTMLElement>(
        "a[href], button:not([disabled]), [tabindex]:not([tabindex=\"-1\"])",
      ),
    );
  }

  function openMenu() {
    if (!mobileMenu || !menuButton) {
      return;
    }

    previousBodyOverflow = document.body.style.overflow;
    mobileMenu.hidden = false;
    mobileMenu.classList.remove("hidden");
    mobileMenu.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    menuButton.setAttribute("aria-expanded", "true");
    closeMenuButton?.focus();
  }

  function closeMenu(restoreFocus = true) {
    if (!mobileMenu || !menuButton) {
      return;
    }

    mobileMenu.classList.add("hidden");
    mobileMenu.hidden = true;
    mobileMenu.setAttribute("aria-hidden", "true");
    document.body.style.overflow = previousBodyOverflow;
    menuButton.setAttribute("aria-expanded", "false");

    if (restoreFocus) {
      menuButton.focus();
    }
  }

  menuButton?.addEventListener("click", function(e) {
    e.preventDefault();
    openMenu();
  });

  closeMenuButton?.addEventListener("click", function(e) {
    e.preventDefault();
    closeMenu();
  });

  document.addEventListener("keydown", function(event) {
    if (!isMenuOpen()) {
      return;
    }

    if (event.key === "Escape") {
      event.preventDefault();
      closeMenu();
      return;
    }

    if (event.key !== "Tab") {
      return;
    }

    const focusableItems = getFocusableMenuItems();
    const firstItem = focusableItems[0];
    const lastItem = focusableItems[focusableItems.length - 1];

    if (!firstItem || !lastItem) {
      return;
    }

    if (event.shiftKey && document.activeElement === firstItem) {
      event.preventDefault();
      lastItem.focus();
    } else if (!event.shiftKey && document.activeElement === lastItem) {
      event.preventDefault();
      firstItem.focus();
    }
  });

  mobileMenu?.addEventListener("click", function(event) {
    if (event.target === mobileMenu) {
      closeMenu();
    }
  });

  mobileMenu?.querySelectorAll("a[href]").forEach((link) => {
    link.addEventListener("click", function() {
      closeMenu(false);
    });
  });
});
</script>
