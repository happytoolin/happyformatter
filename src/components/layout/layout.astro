---
import { toCanonicalURL } from "../../lib/canonical-url";
import { generatePageTitle } from "../../lib/seo-titles";
import { generateBreadcrumbs, getLanguageSEOData } from "../../lib/seo-utils";
import type { ToolFAQItem } from "../../lib/tool-page-seo";
import "../../styles/globals.css";
import MoreTools from "../info/moretools.astro";
import RelatedAndVariants from "../info/RelatedAndVariants.astro";
import Breadcrumbs from "../structured-data/Breadcrumbs.astro";
import FAQSchema from "../structured-data/FAQSchema.astro";
import WebApplicationSchema from "../structured-data/WebApplicationSchema.astro";
import Footer from "./Footer.astro";
import FormatHeading from "./FormatHeading.astro";
import Head from "./Head.astro";
import Header from "./header.astro";

type Props = {
  breadcrumbs?: Array<{ name: string; url: string }>;
  canonicalPath?: string;
  category?: string;
  currentVariant?: string | null;
  description: string;
  faqItems?: ToolFAQItem[];
  image?: string;
  imageAlt?: string;
  keywords?: string;
  language?: string;
  minify?: boolean;
  robots?: string;
  showFormatHeading?: boolean;
  showMoreTools?: boolean;
  showRelatedAndVariants?: boolean;
  structuredDataDescription?: string;
  structuredDataName?: string;
  title: string;
};

const {
  title: _title,
  description: _description,
  breadcrumbs = [],
  canonicalPath,
  category,
  currentVariant = null,
  faqItems = [],
  image,
  imageAlt,
  keywords,
  language,
  minify,
  robots,
  showFormatHeading = true,
  showMoreTools = true,
  showRelatedAndVariants = true,
  structuredDataDescription,
  structuredDataName,
} = Astro.props;

// Get language-specific SEO data
const seoData = getLanguageSEOData(language, minify);

const pageTitle = _title
  || generatePageTitle(language ?? "", currentVariant, minify);
const pageDescription = _description || seoData.description;
const finalBreadcrumbs = breadcrumbs.length > 0
  ? breadcrumbs
  : generateBreadcrumbs(language, minify);
const canonicalURL = toCanonicalURL(
  canonicalPath ?? Astro.url.pathname,
  Astro.site,
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <Head
      title={pageTitle}
      description={pageDescription}
      canonicalPath={canonicalPath}
      image={image}
      imageAlt={imageAlt}
      keywords={keywords || seoData.keywords}
      category={category || seoData.category}
      robots={robots}
    />

    <!-- Structured Data -->
    <WebApplicationSchema
      language={language}
      minify={minify}
      name={structuredDataName || pageTitle}
      description={structuredDataDescription || pageDescription}
      url={canonicalURL}
    />

    <!-- Breadcrumbs Schema -->
    {finalBreadcrumbs.length > 0 && <Breadcrumbs items={finalBreadcrumbs} />}

    <!-- FAQ Schema -->
    {(language || faqItems.length > 0) && (
      <FAQSchema
        language={language}
        items={faqItems}
        name={structuredDataName}
        description={structuredDataDescription}
        url={canonicalURL}
      />
    )}
  </head>
  <body>
    <!-- Skip to main content link for keyboard navigation -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 rounded-md bg-primary px-4 py-2 text-primary-foreground focus:outline-none focus:ring-2 focus:ring-ring"
    >
      Skip to main content
    </a>

    <Header />

    <main
      id="main-content"
      role="main"
      class="w-full max-w-full overflow-x-hidden"
    >
      {language && showFormatHeading && (
        <FormatHeading language={language} minify={minify ?? false} />
      )}
      <slot />
    </main>

    {showRelatedAndVariants && (
      <RelatedAndVariants
        currentLanguage={language}
        currentVariant={currentVariant}
        minify={minify}
      />
    )}
    {showMoreTools && <MoreTools />}
    <Footer />
  </body>
</html>
