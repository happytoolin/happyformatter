---
import type {
  AnySeoContentPage,
  ComparisonPage,
  ErrorGuidePage,
  GuidePage,
} from "@/lib/seo-content";

type Props = {
  page: AnySeoContentPage;
};

const { page } = Astro.props;

const isComparison = page.family === "compare";
const isErrorGuide = page.family === "errors";
const isGuide = page.family === "guides";

const comparison = isComparison ? page as ComparisonPage : null;
const errorGuide = isErrorGuide ? page as ErrorGuidePage : null;
const guide = isGuide ? page as GuidePage : null;
---

<section class="border-b border-border bg-background">
  <div class="mx-auto grid max-w-[1400px] gap-6 px-4 py-10 sm:px-6 md:grid-cols-[minmax(0,1fr)_minmax(260px,420px)] md:items-end lg:px-8 lg:py-14">
    <div class="space-y-4">
      <p class="text-sm font-medium text-muted-foreground">
        Private / No Upload
      </p>
      <h1 class="max-w-5xl text-4xl font-semibold leading-none text-foreground md:text-6xl">
        {page.h1}
      </h1>
    </div>
    <p class="max-w-md text-sm leading-6 text-muted-foreground">
      {page.summary}
    </p>
  </div>
</section>

<section class="border-b border-border bg-background py-8">
  <div class="mx-auto grid max-w-[1400px] gap-4 px-4 sm:px-6 md:grid-cols-3 lg:px-8">
    {["Runs in your browser", "No upload", "No account"].map(item => (
      <div class="rounded-md border border-border bg-card p-4">
        <p class="text-sm font-semibold text-foreground">{item}</p>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          HappyFormatter tools process pasted snippets client-side for quick,
          privacy-first developer workflows.
        </p>
      </div>
    ))}
  </div>
</section>

{comparison && (
  <section class="border-b border-border bg-background py-12 sm:py-16">
    <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_minmax(260px,420px)] lg:px-8">
      <div>
        <h2 class="text-3xl font-semibold text-foreground">Key differences</h2>
        <div class="mt-5 divide-y divide-border border-y border-border">
          {comparison.differences.map(item => (
            <p class="py-4 text-sm leading-6 text-muted-foreground">{item}</p>
          ))}
        </div>
      </div>
      <aside class="rounded-md border border-border bg-card p-5">
        <h2 class="text-xl font-semibold text-foreground">Best for</h2>
        <ul class="mt-4 space-y-3">
          {comparison.bestFor.map(item => (
            <li class="text-sm leading-6 text-muted-foreground">{item}</li>
          ))}
        </ul>
      </aside>
    </div>
  </section>
)}

{errorGuide && (
  <section class="border-b border-border bg-background py-12 sm:py-16">
    <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_minmax(260px,420px)] lg:px-8">
      <div>
        <h2 class="text-3xl font-semibold text-foreground">Fix steps</h2>
        <ol class="mt-5 space-y-3">
          {errorGuide.fixSteps.map((step, index) => (
            <li class="grid grid-cols-[2rem_minmax(0,1fr)] gap-3 text-sm leading-6 text-muted-foreground">
              <span class="font-mono text-foreground">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>
      <aside class="rounded-md border border-border bg-card p-5">
        <h2 class="text-xl font-semibold text-foreground">Common symptoms</h2>
        <ul class="mt-4 space-y-3">
          {errorGuide.symptoms.map(item => (
            <li class="text-sm leading-6 text-muted-foreground">{item}</li>
          ))}
        </ul>
      </aside>
    </div>
  </section>
)}

{guide && (
  <section class="border-b border-border bg-background py-12 sm:py-16">
    <div class="mx-auto max-w-[1000px] px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-semibold text-foreground">Steps</h2>
      <ol class="mt-5 divide-y divide-border border-y border-border">
        {guide.steps.map((step, index) => (
          <li class="grid gap-3 py-4 text-sm leading-6 text-muted-foreground sm:grid-cols-[3rem_minmax(0,1fr)]">
            <span class="font-mono text-foreground">{index + 1}</span>
            <span>{step}</span>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}

<section class="border-b border-border bg-background py-12 sm:py-16">
  <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
    <div class="grid gap-6 lg:grid-cols-2">
      {page.examples.map(example => (
        <article class="overflow-hidden rounded-md border border-border bg-card">
          <div class="border-b border-border px-4 py-3">
            <p class="text-sm font-semibold text-foreground">{example.label}</p>
            <p class="mt-1 text-sm leading-6 text-muted-foreground">
              {example.description}
            </p>
          </div>
          <pre class="overflow-auto p-4 text-sm leading-6"><code>{example.input}</code></pre>
          <div class="border-t border-border bg-background p-4">
            <p class="mb-2 font-mono text-xs uppercase text-muted-foreground">
              Output
            </p>
            <pre class="overflow-auto text-sm leading-6"><code>{example.output}</code></pre>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="border-b border-border bg-background py-12 sm:py-16">
  <div class="mx-auto grid max-w-[1400px] gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_minmax(260px,420px)] lg:px-8">
    <div>
      <h2 class="text-3xl font-semibold text-foreground">Related pages</h2>
      <div class="mt-5 divide-y divide-border border-y border-border">
        {page.relatedLinks.map(link => (
          <article class="grid gap-3 py-4 md:grid-cols-[minmax(180px,0.3fr)_minmax(0,1fr)_auto] md:items-center">
            <a
              href={link.href}
              class="text-base font-semibold text-foreground underline-offset-4 hover:underline"
            >
              {link.title}
            </a>
            <p class="text-sm leading-6 text-muted-foreground">
              {link.description}
            </p>
            <span
              class="w-fit rounded-md border border-border bg-card px-2.5 py-1 text-xs text-muted-foreground"
            >
              {link.group}
            </span>
          </article>
        ))}
      </div>
    </div>
    <aside>
      <h2 class="text-2xl font-semibold text-foreground">FAQs</h2>
      <div class="mt-5 space-y-4">
        {page.faqs.map(item => (
          <article class="rounded-md border border-border bg-card p-4">
            <h3 class="text-base font-semibold text-foreground">
              {item.title}
            </h3>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {item.content}
            </p>
          </article>
        ))}
      </div>
    </aside>
  </div>
</section>
