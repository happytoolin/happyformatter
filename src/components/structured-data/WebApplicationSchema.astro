---
import { LANGUAGES } from "@/lib/languages";

interface Props {
  url?: URL | string;
  name?: string;
  description?: string;
  language?: string;
  minify?: boolean;
}

const {
  url = Astro.url,
  name = "HappyFormatter",
  description =
    "Privacy-focused code formatter and minifier for 26+ programming languages",
  language,
  minify = false,
} = Astro.props;

const languageName = language
  ? LANGUAGES[language]?.name
    || language.charAt(0).toUpperCase() + language.slice(1)
  : null;
const actionName = minify ? "Minifier" : "Formatter";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": languageName ? name || `${languageName} Code ${actionName}` : name,
  "description": languageName
    ? description
      || `${
        minify ? "Minify" : "Format"
      } ${languageName} code in the browser with privacy-focused local processing.`
    : description,
  "url": typeof url === "string" ? url : url.href,
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any browser with WebAssembly support",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD",
  },
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(schema)}>
</script>
