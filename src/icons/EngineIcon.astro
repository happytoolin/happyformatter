---
import {
  siBiome,
  type SimpleIcon,
  siOxc,
  siPrettier,
  siRuff,
  siSwc,
} from "simple-icons";

interface Props {
  class?: string;
  engine: string;
  title?: string;
}

const { class: className = "h-5 w-5", engine, title } = Astro.props;

const normalizeEngine = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]+/g, "");

const simpleIcons: Record<string, SimpleIcon> = {
  biome: siBiome,
  oxc: siOxc,
  prettier: siPrettier,
  ruff: siRuff,
  ruffformatter: siRuff,
  swc: siSwc,
};

const normalizedEngine = normalizeEngine(engine);
const simpleIcon = simpleIcons[normalizedEngine];
const accessibleTitle = title ?? engine;
---

{simpleIcon
  ? (
    <svg
      class={className}
      viewBox="0 0 24 24"
      fill="currentColor"
      role="img"
      aria-label={accessibleTitle}
    >
      <path d={simpleIcon.path}></path>
    </svg>
  )
  : normalizedEngine.includes("lightningcss")
  ? (
    <svg
      class={className}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.9"
      stroke-linecap="round"
      stroke-linejoin="round"
      role="img"
      aria-label={accessibleTitle}
    >
      <path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"></path>
    </svg>
  )
  : (
    <svg
      class={className}
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
      role="img"
      aria-label={accessibleTitle}
    >
      <path d="M4 6.5h16"></path>
      <path d="M7 12h10"></path>
      <path d="M10 17.5h4"></path>
      <path d="M5 3.5h14a1.5 1.5 0 0 1 1.5 1.5v14A1.5 1.5 0 0 1 19 20.5H5A1.5 1.5 0 0 1 3.5 19V5A1.5 1.5 0 0 1 5 3.5Z">
      </path>
    </svg>
  )}
