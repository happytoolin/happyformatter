---
import Info from "@/components/info/info-enhanced.astro";
import ToolExamples from "@/components/info/ToolExamples.astro";
import ReactIsland from "@/components/islands/ReactIsland.astro";
import Layout from "@/components/layout/layout.astro";
import { type LanguageConfig, LANGUAGES } from "@/lib/languages";
import { buildToolPageSEO } from "@/lib/tool-page-seo";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = (async () => {
  const paths: any[] = [];

  // Add main language pages (single segment)
  Object.entries(LANGUAGES).forEach(([langId, langConfig]) => {
    paths.push({
      params: { lang: langId },
      props: {
        languageConfig: langConfig,
        language: langId,
        variant: null,
        lang: langId,
      },
    });
  });

  // Add canonical hyphenated variant pages (e.g., "javascript-biome")
  const { getLanguageVariants } = await import("@/lib/seo-variants");

  for (const [langId, langConfig] of Object.entries(LANGUAGES)) {
    const variants = getLanguageVariants(langId);

    variants.forEach(variant => {
      if (variant.slug === "minify") {
        return;
      }

      paths.push({
        params: { lang: `${langId}-${variant.slug}` },
        props: {
          languageConfig: langConfig,
          language: langId,
          variant: variant.slug,
          variantData: variant,
          lang: `${langId}-${variant.slug}`,
        },
      });
    });
  }

  return paths;
}) satisfies GetStaticPaths;

interface Props {
  languageConfig: LanguageConfig;
  language: string;
  variant?: string | null;
  variantData?: any;
  lang: string;
}

const { language, languageConfig, variant, variantData, lang } = Astro.props;

// Parse the lang parameter to detect variant or hyphenated language
const langParam = lang;
const pathSegments = langParam ? langParam.split("/") : [];
const detectedVariant = pathSegments.length > 1 ? pathSegments[1] : null;

// Check if the first segment is a hyphenated variant (e.g., "javascript-biome")
const firstSegment = pathSegments[0];
const hyphenatedParts = firstSegment ? firstSegment.split("-") : [];
let baseLanguage = language;
let hyphenatedVariant = null;

if (hyphenatedParts.length >= 2) {
  // This might be a hyphenated variant like "javascript-biome"
  const potentialBaseLanguage = hyphenatedParts[0];
  const potentialVariant = hyphenatedParts.slice(1).join("-");

  // Check if the base language exists and the variant is valid for it
  if (LANGUAGES[potentialBaseLanguage]) {
    const { getLanguageVariant } = await import("@/lib/seo-variants");
    const variantData = getLanguageVariant(
      potentialBaseLanguage,
      potentialVariant,
    );

    if (variantData) {
      baseLanguage = potentialBaseLanguage;
      hyphenatedVariant = potentialVariant;
    }
  }
}

// Safety checks
if (!language || !languageConfig) {
  throw new Error(
    `Language or languageConfig is undefined. Language: ${language}, Path: ${
      pathSegments.join("/")
    }`,
  );
}

// Use detected variant (hyphenated or path-based) or provided variant
const currentVariant = variant || detectedVariant || hyphenatedVariant;
const actualLanguage = baseLanguage;

// Get variant data if we have a variant
let actualVariantData = variantData;
if (currentVariant && !actualVariantData) {
  const { getLanguageVariant } = await import("@/lib/seo-variants");
  actualVariantData = getLanguageVariant(actualLanguage, currentVariant);
}

const isVariant = currentVariant && actualVariantData;
// Get the actual language config (in case we detected a hyphenated variant)
const actualLanguageConfig = LANGUAGES[actualLanguage] || languageConfig;
const runtimeFormatterVariants = new Set(["biome", "ruff", "mago", "oxc"]);
const formatterLanguage =
  currentVariant && runtimeFormatterVariants.has(currentVariant)
    ? `${actualLanguage}-${currentVariant}`
    : actualLanguage;
const toolSEO = buildToolPageSEO({
  language: actualLanguage,
  languageConfig: actualLanguageConfig,
  minify: currentVariant === "minify",
  variant: currentVariant,
  variantData: actualVariantData,
});
const displayVariantData = currentVariant ? { h1: toolSEO.h1 } : null;
---

<Layout
  title={toolSEO.title}
  description={toolSEO.description}
  language={actualLanguage}
  minify={currentVariant === "minify"}
  canonicalPath={toolSEO.canonicalPath}
  keywords={toolSEO.keywords}
  category={toolSEO.category}
  currentVariant={currentVariant}
  breadcrumbs={toolSEO.breadcrumbs}
  faqItems={toolSEO.faqItems}
  showFormatHeading={!currentVariant}
  structuredDataName={toolSEO.schemaName}
  structuredDataDescription={toolSEO.schemaDescription}
>
  {/* Custom heading for variant pages */}
  {isVariant && (
    <div class="mx-auto max-w-[1400px] px-4 py-6 sm:px-6 lg:px-8">
      <div class="mb-6 border-y border-border py-5">
        <div class="mb-2 flex flex-col gap-3 sm:flex-row sm:items-center">
          <h1 class="text-2xl font-semibold text-foreground md:text-3xl">
            {toolSEO.h1}
          </h1>
          <span
            class="w-fit rounded-md border border-border bg-card px-2.5 py-1 text-sm text-muted-foreground"
          >
            {actualLanguageConfig.name}
          </span>
        </div>
        <p class="text-muted-foreground leading-relaxed">
          {toolSEO.description}
        </p>
        <div class="mt-4 flex items-center gap-2">
          <a
            href={`/${actualLanguage}`}
            class="inline-flex rounded-md border border-border bg-card px-3 py-2 text-sm font-medium text-foreground transition-[background-color,border-color,transform] duration-150 ease-out hover:border-foreground hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring active:translate-y-px motion-reduce:transition-none"
          >
            Back to
            {actualLanguageConfig.name}
            Formatter
          </a>
        </div>
      </div>
    </div>
  )}

  <ReactIsland
    kind="formatter"
    props={{ minifier: actualLanguageConfig.minify, language: formatterLanguage }}
  />

  <ToolExamples
    language={actualLanguage}
    minify={currentVariant === "minify"}
    variant={currentVariant}
  />

  <Info
    language={actualLanguage}
    minify={currentVariant === "minify"}
    variant={currentVariant}
    variantData={displayVariantData}
  />

  <ReactIsland
    kind="faq-enhanced"
    props={{
      language: actualLanguage,
      minify: currentVariant === "minify",
      variant: currentVariant,
      variantData: displayVariantData,
    }}
  />
</Layout>
