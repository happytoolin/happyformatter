---
import Layout from "@/components/layout/layout.astro";
import SeoContentHub from "@/components/seo/SeoContentHub.astro";
import { getSeoHubBreadcrumbs, SEO_HUBS } from "@/lib/seo-content";

const hub = SEO_HUBS.guides;
---

<Layout
  title={hub.title}
  description={hub.description}
  canonicalPath={hub.canonicalPath}
  keywords="private formatter guides, no upload converter guides, developer tool guides"
  breadcrumbs={getSeoHubBreadcrumbs("guides")}
  showFormatHeading={false}
  structuredDataName={hub.h1}
  structuredDataDescription={hub.description}
>
  <SeoContentHub family="guides" />
</Layout>
