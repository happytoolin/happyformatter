---
import Info from "@/components/info/info.astro";
import ReactIsland from "@/components/islands/ReactIsland.astro";
import Layout from "@/components/layout/layout.astro";
import { LANGUAGES } from "@/lib/languages";

const language = "json";
const languageConfig = LANGUAGES[language];

const homepageTitle =
  "Browser Code Formatter & Minifier - 22+ Languages | HappyFormatter";
const homepageDescription =
  "Format and minify code for 22+ programming languages in your browser. Paste code, run the action, and copy the result.";
const homepageKeywords =
  "online code formatter, code minifier, free code formatter, format code online, code beautifier, web formatter, code formatting tool, programmer tools, developer tools";
---

<Layout
  title={homepageTitle}
  description={homepageDescription}
  keywords={homepageKeywords}
>
  <section class="border-b border-border bg-background">
    <div class="mx-auto grid max-w-[1400px] gap-6 px-4 py-10 sm:px-6 md:grid-cols-[minmax(0,1fr)_minmax(260px,420px)] md:items-end lg:px-8 lg:py-14">
      <div class="space-y-4">
        <p class="text-sm font-medium text-muted-foreground">
          Local formatter
        </p>
        <h1 class="max-w-5xl text-5xl font-semibold leading-none text-foreground md:text-6xl">
          Format code without leaving your browser.
        </h1>
      </div>
      <p class="max-w-md text-sm leading-6 text-muted-foreground">
        Start with JSON or jump to any formatter below. Formatting runs
        client-side and keeps your code on this device.
      </p>
    </div>
  </section>
  <ReactIsland
    kind="formatter"
    props={{ minifier: languageConfig.minify, language }}
  />
  <Info language={language} />
  <ReactIsland kind="faq" props={{ language }} />
</Layout>
