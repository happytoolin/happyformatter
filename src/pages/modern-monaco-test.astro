---
import Header from "@/components/layout/header.astro";
import { themePreferenceStorageKey, themeStorageKey } from "@/lib/theme";
import { modernMonacoEditorCoreUrl } from "happyformatter:modern-monaco-runtime";
import "../styles/globals.css";

const modernMonacoImportMap = JSON.stringify(
  {
    imports: {
      "modern-monaco/editor-core": modernMonacoEditorCoreUrl,
    },
  },
  null,
  2,
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="color-scheme" content="light dark" />
    <title>Modern Monaco Test | HappyFormatter</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="importmap" is:inline set:html={modernMonacoImportMap}>
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script
      is:inline
      define:vars={{ themePreferenceStorageKey, themeStorageKey }}
    >
    (() => {
      const root = document.documentElement;
      const systemThemeQuery = window.matchMedia(
        "(prefers-color-scheme: dark)",
      );
      const readStorage = (key) => {
        try {
          return window.localStorage.getItem(key);
        } catch {
          return null;
        }
      };
      const writeStorage = (key, value) => {
        try {
          window.localStorage.setItem(key, value);
        } catch {
          // Storage can be unavailable in private browsing modes.
        }
      };
      const isMode = (value) => value === "light" || value === "dark";
      const isPreference = (value) => value === "system" || isMode(value);
      const storedPreference = readStorage(themePreferenceStorageKey);
      const preference = isPreference(storedPreference)
        ? storedPreference
        : "system";
      const mode = preference === "system"
        ? systemThemeQuery.matches ? "dark" : "light"
        : preference;

      root.classList.toggle("dark", mode === "dark");
      root.dataset.theme = mode;
      root.dataset.themePreference = preference;
      root.style.colorScheme = mode;
      writeStorage(themeStorageKey, mode);
    })();
    </script>
    <style is:inline>
    #modern-monaco-test-root code,
    #modern-monaco-test-root pre,
    #modern-monaco-test-root .monaco-editor {
      font-family:
        "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    }
    </style>
  </head>
  <body class="bg-background text-foreground">
    <Header />
    <main
      id="main-content"
      role="main"
      class="w-full max-w-full overflow-x-hidden"
    >
      <div id="modern-monaco-test-root"></div>
    </main>
    <script>
    import "@/components/playground/ModernMonacoTestClient";
    </script>
  </body>
</html>
