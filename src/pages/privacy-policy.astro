---
import FormatHeading from "@/components/layout/FormatHeading.astro";
import Layout from "@/components/layout/layout.astro";

const privacyFeatures = [
  {
    title: "Local processing",
    body:
      "Formatting and minification run in your browser through client-side modules.",
    points: ["No server uploads", "No code storage", "No account required"],
  },
  {
    title: "Minimal analytics",
    body:
      "Basic aggregate analytics may be used to understand tool usage and improve reliability.",
    points: [
      "No source code collection",
      "No advertising profile",
      "No sale of user data",
    ],
  },
];

const details = [
  {
    title: "Processing architecture",
    body:
      "HappyFormatter loads the formatter implementation in the browser and runs the operation locally. The source you paste is not sent to a formatting API.",
  },
  {
    title: "Browser security",
    body:
      "The browser sandbox and same-origin policy limit what page code can access. The formatter cannot read arbitrary local files.",
  },
  {
    title: "Analytics implementation",
    body:
      "Anonymous page-level usage metrics may be collected. Those metrics do not include the code you paste into the editor.",
  },
];
---

<Layout
  title="Privacy Policy"
  description="HappyFormatter's privacy policy - We don't collect your data. All formatting happens locally in your browser."
>
  <FormatHeading language="privacy" minify={false} />

  <section class="border-b border-border bg-card py-16 sm:py-20">
    <div class="mx-auto grid max-w-[1400px] gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(220px,0.3fr)_minmax(0,1fr)] lg:px-8">
      <div class="space-y-4">
        <p class="text-sm font-medium text-muted-foreground">
          Policy
        </p>
        <h2 class="text-3xl font-semibold leading-tight md:text-4xl">
          Your code stays on your device.
        </h2>
        <p class="max-w-md text-sm leading-6 text-muted-foreground">
          HappyFormatter is designed around local browser processing. The
          formatter does not require an account, upload, or server-side
          formatting call.
        </p>
      </div>

      <div class="space-y-8">
        <div class="divide-y divide-border border-y border-border">
          {privacyFeatures.map((feature) => (
            <article class="grid gap-5 py-6 md:grid-cols-[minmax(180px,0.35fr)_1fr]">
              <div>
                <h3 class="text-xl font-semibold">
                  {feature.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  {feature.body}
                </p>
              </div>
              <ul class="space-y-2 text-sm text-foreground">
                {feature.points.map((point) => (
                  <li class="flex gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ring"
                      aria-hidden="true"
                    />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <div class="border-y border-border py-6">
          <h3 class="text-xl font-semibold">
            Technical details
          </h3>
          <div class="mt-6 divide-y divide-border">
            {details.map((detail) => (
              <div class="grid gap-2 py-5 first:pt-0 last:pb-0 sm:grid-cols-[180px_1fr]">
                <h4 class="text-sm font-medium text-muted-foreground">
                  {detail.title}
                </h4>
                <p class="text-sm leading-6 text-foreground">
                  {detail.body}
                </p>
              </div>
            ))}
          </div>
        </div>

        <p class="font-mono text-xs text-muted-foreground">
          Last updated: December 2025
        </p>
      </div>
    </div>
  </section>
</Layout>
