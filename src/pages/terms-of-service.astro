---
import FormatHeading from "@/components/layout/FormatHeading.astro";
import Layout from "@/components/layout/layout.astro";

const termGroups = [
  {
    title: "What you get",
    body:
      "A free browser-based code formatter with local processing and no registration flow.",
    points: [
      "Instant formatting",
      "Multiple language handlers",
      "Client-side operation",
      "No account required",
    ],
  },
  {
    title: "What is not guaranteed",
    body:
      "HappyFormatter is provided as-is. You are responsible for reviewing output before using it in production.",
    points: [
      "No warranties",
      "No guaranteed availability",
      "No support commitment",
      "No liability for output",
    ],
  },
];

const details = [
  {
    title: "Code ownership",
    body:
      "You retain ownership of the code you paste into HappyFormatter. The tool does not claim rights over your source.",
  },
  {
    title: "Service availability",
    body:
      "The service may change, become unavailable, or be discontinued without advance notice.",
  },
  {
    title: "Acceptable use",
    body:
      "Do not use the service for illegal activity or to interfere with the availability of the site.",
  },
  {
    title: "Data collection",
    body:
      "Your code is processed locally in the browser. Basic analytics may be used as described in the privacy policy.",
  },
];
---

<Layout
  title="Terms of Service"
  description="HappyFormatter's terms of service - Free browser-based tool for code formatting."
>
  <FormatHeading language="terms" minify={false} />

  <section class="border-b border-border bg-card py-16 sm:py-20">
    <div class="mx-auto grid max-w-[1400px] gap-8 px-4 sm:px-6 lg:grid-cols-[minmax(220px,0.3fr)_minmax(0,1fr)] lg:px-8">
      <div class="space-y-4">
        <p class="text-sm font-medium text-muted-foreground">
          Terms
        </p>
        <h2 class="text-3xl font-semibold leading-tight md:text-4xl">
          Use the tool, review the output.
        </h2>
        <p class="max-w-md text-sm leading-6 text-muted-foreground">
          HappyFormatter is a free browser utility. It is built for convenience,
          not as a substitute for your own code review and testing.
        </p>
      </div>

      <div class="space-y-8">
        <div class="divide-y divide-border border-y border-border">
          {termGroups.map((group) => (
            <article class="grid gap-5 py-6 md:grid-cols-[minmax(180px,0.35fr)_1fr]">
              <div>
                <h3 class="text-xl font-semibold">
                  {group.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-muted-foreground">
                  {group.body}
                </p>
              </div>
              <ul class="space-y-2 text-sm text-foreground">
                {group.points.map((point) => (
                  <li class="flex gap-2">
                    <span
                      class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-ring"
                      aria-hidden="true"
                    />
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))}
        </div>

        <div class="border-y border-border py-6">
          <h3 class="text-xl font-semibold">Fine print</h3>
          <div class="mt-6 divide-y divide-border">
            {details.map((detail) => (
              <div class="grid gap-2 py-5 first:pt-0 last:pb-0 sm:grid-cols-[180px_1fr]">
                <h4 class="text-sm font-medium text-muted-foreground">
                  {detail.title}
                </h4>
                <p class="text-sm leading-6 text-foreground">
                  {detail.body}
                </p>
              </div>
            ))}
          </div>
        </div>

        <p class="font-mono text-xs text-muted-foreground">
          Last updated: December 2025
        </p>
      </div>
    </div>
  </section>
</Layout>
