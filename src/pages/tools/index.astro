---
import Layout from "@/components/layout/layout.astro";
import {
  getUtilityToolsByCategory,
  UTILITY_CATEGORIES,
  UTILITY_TOOLS,
} from "@/lib/utility-tools";

const title = "Private Browser Developer Tools - No Upload | HappyFormatter";
const description =
  "Use private browser developer tools for formatting, minifying, JSON, URL, Base64, JWT, hash, regex, and color workflows. Tools run locally with no upload.";
const keywords =
  "private developer tools, browser tools, no upload tools, json tools, formatter tools, minifier tools, jwt decoder, base64 tool";

const topLinks = [
  {
    name: "Private tools hub",
    url: "/tools/private",
    description:
      "No-upload formatter, minifier, converter, decoder, parser, and generator workflows.",
  },
  {
    name: "Formatters",
    url: "/tools/formatters",
    description:
      "Code formatters for JSON, JavaScript, CSS, HTML, Python, SQL, XML, YAML, and more.",
  },
  {
    name: "Minifiers",
    url: "/tools/minifiers",
    description:
      "Browser minifiers for JSON, JavaScript, TypeScript, CSS, SCSS, and XML.",
  },
  ...UTILITY_CATEGORIES.map(category => ({
    name: category.name,
    url: `/tools/${category.slug}`,
    description: category.description,
  })),
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalPath="/tools"
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Tools", url: "/tools" },
  ]}
  faqItems={[
    {
      title: "Are HappyFormatter tools private?",
      content:
        "Yes. Formatter, minifier, and utility tools are designed to process pasted text in your browser instead of uploading it to a server.",
    },
    {
      title: "Which developer tools are available?",
      content:
        "HappyFormatter includes code formatters, minifiers, JSON tools, converters, JWT decoding, Base64, URL encoding, hashing, regex testing, and color conversion.",
    },
    {
      title: "Do I need an account?",
      content:
        "No. The tools are free to use in the browser and do not require an account.",
    },
  ]}
  structuredDataName="HappyFormatter Private Browser Developer Tools"
  structuredDataDescription={description}
  showFormatHeading={false}
>
  <section class="border-b border-border bg-background">
    <div class="mx-auto grid max-w-[1400px] gap-6 px-4 py-10 sm:px-6 md:grid-cols-[minmax(0,1fr)_minmax(260px,420px)] md:items-end lg:px-8 lg:py-14">
      <div class="space-y-4">
        <p class="text-sm font-medium text-muted-foreground">
          Private browser tools
        </p>
        <h1 class="max-w-5xl text-5xl font-semibold leading-none text-foreground md:text-6xl">
          Developer tools that keep pasted text local.
        </h1>
      </div>
      <p class="max-w-md text-sm leading-6 text-muted-foreground">
        Format, minify, convert, encode, decode, compare, and hash without
        sending snippets away from this browser tab.
      </p>
    </div>
  </section>

  <section class="border-b border-border bg-background py-10 sm:py-12">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {topLinks.map(link => (
          <a
            href={link.url}
            class="rounded-md border border-border bg-card p-5 transition-colors hover:border-foreground hover:bg-secondary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            <h2 class="text-lg font-semibold text-foreground">{link.name}</h2>
            <p class="mt-3 text-sm leading-6 text-muted-foreground">
              {link.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-background py-12 sm:py-16">
    <div class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-4 border-b border-border pb-4">
        <div>
          <p class="text-sm font-medium text-muted-foreground">
            Utility pages
          </p>
          <h2 class="mt-2 text-3xl font-semibold leading-tight text-foreground">
            Browser-only helpers
          </h2>
        </div>
        <span class="text-sm text-muted-foreground">
          {UTILITY_TOOLS.length} utility tools
        </span>
      </div>

      <div class="space-y-10">
        {UTILITY_CATEGORIES.map(category => {
          const categoryTools = getUtilityToolsByCategory(category.id);
          return (
            <section id={`tools-${category.slug}`}>
              <div class="mb-3 flex items-center justify-between gap-4">
                <h3 class="text-xl font-semibold text-foreground">
                  {category.name}
                </h3>
                <a
                  href={`/tools/${category.slug}`}
                  class="text-sm font-medium text-foreground underline-offset-4 hover:underline"
                >
                  View category
                </a>
              </div>
              <div class="divide-y divide-border border-y border-border">
                {categoryTools.map(tool => (
                  <article class="grid gap-3 py-4 md:grid-cols-[minmax(190px,0.28fr)_minmax(0,1fr)_auto] md:items-center">
                    <a
                      href={`/tools/${tool.slug}`}
                      class="text-base font-medium text-foreground underline-offset-4 hover:underline"
                    >
                      {tool.name}
                    </a>
                    <p class="text-sm leading-6 text-muted-foreground">
                      {tool.description}
                    </p>
                    <a
                      href={`/tools/${tool.slug}`}
                      class="hf-button hf-button-outline hf-button-md"
                    >
                      Open
                    </a>
                  </article>
                ))}
              </div>
            </section>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
