{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "happyformatter-www-redirect",
  "main": "./src/www-redirect-worker.js",
  "compatibility_date": "2025-11-17",
  "routes": [
    {
      "pattern": "www.happyformatter.com/*",
      "zone_name": "happyformatter.com",
    },
  ],
}
